<Window x:Class="OpenWire.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:OpenWire.App.Views"
        xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="OpenWire" Height="820" Width="1300" MinHeight="620" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgApp}"
        FontFamily="{StaticResource UiFont}"
        TextOptions.TextFormattingMode="Ideal">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="60" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:TrafficViewModel}"><views:TrafficView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AnalyticsViewModel}"><views:AnalyticsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:FirewallViewModel}"><views:FirewallView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlertsViewModel}"><views:AlertsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ThingsViewModel}"><views:ThingsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HardwareViewModel}"><views:HardwareView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- paper grain over the whole window (transparent in the Minimal skin) -->
        <Rectangle Grid.Row="0" Grid.RowSpan="2" Fill="{StaticResource PaperOverlay}" IsHitTestVisible="False" Panel.ZIndex="-1" />

        <!-- ===================== TOP BAR ===================== -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource AccentSoft}"
                            BorderBrush="{StaticResource SketchBorderBrush}" BorderThickness="1.3">
                        <Path Data="{StaticResource DoodleWifi}" Stretch="Uniform" Width="18" Height="18"
                              Stroke="{StaticResource Accent}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="OpenWire" FontFamily="{StaticResource HeadingFont}" FontSize="19" />
                        <TextBlock Text="OPEN SOURCE" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="1,-2,0,0" />
                    </StackPanel>
                    <Path Data="{StaticResource DoodleStar}" Style="{StaticResource DoodleFill}" Width="16" Height="16"
                          VerticalAlignment="Top" Margin="6,4,0,0" />
                </StackPanel>

                <!-- Tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource TopTab}"><Setter Property="GroupName" Value="tabs" /></Style>
                    </StackPanel.Resources>
                    <RadioButton Content="Traffic" Tag="&#xE9D9;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Traffic, Mode=TwoWay}" />
                    <RadioButton Content="Analytics" Tag="&#xE9D2;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Analytics, Mode=TwoWay}" />
                    <RadioButton Content="Firewall" Tag="&#xE83D;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Firewall, Mode=TwoWay}" />
                    <RadioButton Tag="&#xEA8F;" AutomationProperties.Name="Alerts" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Alerts, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Alerts" VerticalAlignment="Center" />
                            <Border Background="{StaticResource AlertNew}" CornerRadius="9" MinWidth="18" Height="18" Padding="5,0" Margin="7,0,0,0"
                                    VerticalAlignment="Center" Visibility="{Binding UnreadAlerts, Converter={StaticResource ZeroVis}}">
                                <TextBlock Text="{Binding UnreadAlerts}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Content="Scanner" Tag="&#xE968;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Scanner, Mode=TwoWay}" />
                    <RadioButton Content="Hardware" Tag="&#xE950;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Hardware, Mode=TwoWay}" />
                </StackPanel>

                <!-- Right: settings + window buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource IconBtn}" Content="&#xE713;" ToolTip="Settings" Command="{Binding ShowSettingsCommand}" Margin="0,0,4,0" />
                    <Button Style="{StaticResource IconBtn}" Content="&#xE921;" Click="OnMinimize" />
                    <Button Style="{StaticResource IconBtn}" Content="&#xE922;" Click="OnMaximize" />
                    <Button Style="{StaticResource IconBtn}" Content="&#xE8BB;" Click="OnClose" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== CONTENT ===================== -->
        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentView}" />

            <Border Background="{StaticResource BgApp}" Visibility="{Binding IsConnected, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE839;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                    <TextBlock Text="Connecting to the OpenWire engine…" Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,18,0,4" FontSize="15" />
                    <TextBlock Text="The engine must run as administrator to monitor and enforce." Style="{StaticResource Caption}"
                               HorizontalAlignment="Center" />
                    <Button Content="Start engine (admin)" Style="{StaticResource Btn}" Command="{Binding StartEngineCommand}"
                            HorizontalAlignment="Center" Margin="0,20,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
