<Window x:Class="OpenWire.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:OpenWire.App.Views"
        xmlns:util="clr-namespace:OpenWire.App.Util"
        xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="OpenWire" Height="820" Width="1300" MinHeight="620" MinWidth="900"
        Icon="Assets/app.ico"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgApp}"
        FontFamily="{StaticResource UiFont}"
        TextOptions.TextFormattingMode="Ideal">

    <WindowChrome.WindowChrome>
        <!-- The 1px bottom glass keeps DWM composition alive so the window gets the
             system drop shadow (with GlassFrameThickness=0 the frame — and the
             shadow with it — is stripped entirely). -->
        <WindowChrome CaptionHeight="60" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Each section view is built once and reused on every tab switch (no
             visual-tree rebuild → instant switching, scroll positions preserved).
             Window-scoped so a theme/language reskin gets a fresh cache. -->
        <util:CachedViewConverter x:Key="CachedView" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- paper grain over the whole window (transparent in the Minimal skin) -->
        <Rectangle Grid.Row="0" Grid.RowSpan="2" Fill="{StaticResource PaperOverlay}" IsHitTestVisible="False" Panel.ZIndex="-1" />

        <!-- ===================== TOP BAR ===================== -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/logo-small.png" Width="32" Height="32"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="OpenWire" FontFamily="{StaticResource HeadingFont}" FontSize="19" />
                        <TextBlock Text="OPEN SOURCE" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="1,-2,0,0" />
                    </StackPanel>
                    <Path Data="{StaticResource DoodleStar}" Style="{StaticResource DoodleFill}" Width="16" Height="16"
                          VerticalAlignment="Top" Margin="6,4,0,0" />
                </StackPanel>

                <!-- Tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource TopTab}"><Setter Property="GroupName" Value="tabs" /></Style>
                    </StackPanel.Resources>
                    <RadioButton Content="{StaticResource L.Nav.Traffic}" Tag="&#xE9D9;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Traffic, Mode=TwoWay}" />
                    <RadioButton Content="{StaticResource L.Nav.Analytics}" Tag="&#xE9D2;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Analytics, Mode=TwoWay}" />
                    <RadioButton Content="{StaticResource L.Nav.Firewall}" Tag="&#xE83D;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Firewall, Mode=TwoWay}" />
                    <RadioButton Tag="&#xEA8F;" AutomationProperties.Name="Alerts" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Alerts, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{StaticResource L.Nav.Alerts}" VerticalAlignment="Center" />
                            <Border Background="{StaticResource AlertNew}" CornerRadius="9" MinWidth="18" Height="18" Padding="5,0" Margin="7,0,0,0"
                                    VerticalAlignment="Center" Visibility="{Binding UnreadAlerts, Converter={StaticResource ZeroVis}}">
                                <TextBlock Text="{Binding UnreadAlerts}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Content="{StaticResource L.Nav.Scanner}" Tag="&#xE968;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Scanner, Mode=TwoWay}" />
                    <RadioButton Content="{StaticResource L.Nav.Hardware}" Tag="&#xE950;" IsChecked="{Binding CurrentSection, Converter={StaticResource EnumMatch}, ConverterParameter=Hardware, Mode=TwoWay}" />
                </StackPanel>

                <!-- Right: settings + window buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource IconBtn}" Content="&#xE713;" ToolTip="{StaticResource L.Shell.Settings}" Command="{Binding ShowSettingsCommand}" Margin="0,0,4,0" />
                    <Button Style="{StaticResource IconBtn}" Content="&#xE921;" Click="OnMinimize" />
                    <Button Style="{StaticResource IconBtn}" Content="&#xE922;" Click="OnMaximize" />
                    <Button Style="{StaticResource IconBtn}" Content="&#xE8BB;" Click="OnClose" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== CONTENT ===================== -->
        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentView, Converter={StaticResource CachedView}}" />

            <Border Background="{StaticResource BgApp}" Visibility="{Binding IsConnected, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE839;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                    <TextBlock Text="{StaticResource L.Shell.ConnectingEngine}" Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,18,0,4" FontSize="15" />
                    <TextBlock Text="{StaticResource L.Shell.EngineAdminHint}" Style="{StaticResource Caption}"
                               HorizontalAlignment="Center" />
                    <Button Content="{StaticResource L.Shell.StartEngine}" Style="{StaticResource Btn}" Command="{Binding StartEngineCommand}"
                            HorizontalAlignment="Center" Margin="0,20,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
