<UserControl x:Class="OpenWire.App.Views.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:AlertsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Alerts" Style="{StaticResource H1}" VerticalAlignment="Center" />
            <Button Content="Mark all read" Style="{StaticResource BtnGhost}" HorizontalAlignment="Right"
                    Command="{Binding MarkAllReadCommand}" />
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding EmptyText}" Style="{StaticResource Caption}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"
                   Visibility="{Binding Alerts.Count, Converter={StaticResource ZeroVis}, ConverterParameter=invert}" />

        <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}"
                 ItemsSource="{Binding Alerts}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="4,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="9" Height="9" VerticalAlignment="Top" Margin="4,4,0,0"
                                     Fill="{Binding Severity, Converter={StaticResource SevBrush}}" />
                            <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Top" Margin="12,0,0,0"
                                       Text="{Binding Time, Converter={StaticResource LocalTime}}" />
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextSecondary}" FontSize="12.5"
                                           TextWrapping="Wrap" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
