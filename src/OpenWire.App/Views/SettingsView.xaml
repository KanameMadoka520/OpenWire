<UserControl x:Class="OpenWire.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource H1}" Margin="0,0,0,14" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                <TextBlock Text="SECURITY MONITORS" Style="{StaticResource TableHeaderText}" Margin="2,4,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="New device on network" IsChecked="{Binding MonitorNewDevices}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="DNS server changes" IsChecked="{Binding MonitorDnsChanges}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="Remote Desktop (RDP) connections" IsChecked="{Binding MonitorRdp}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="Show desktop notifications" IsChecked="{Binding ShowNotifications}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="RESOLUTION" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="Resolve host names (reverse DNS)" IsChecked="{Binding ResolveHostNames}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="Resolve countries (GeoIP)" IsChecked="{Binding ResolveGeoIp}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="DATA PLAN" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="Enable monthly data plan" IsChecked="{Binding DataPlanEnabled}" Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding DataPlanEnabled}">
                            <TextBlock Text="Limit (GB)" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="120" />
                            <TextBox Style="{StaticResource Search}" Width="120" Text="{Binding DataLimitGb}" />
                            <TextBlock Text="Reset day" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="90" Margin="24,0,0,0" />
                            <TextBox Style="{StaticResource Search}" Width="80" Text="{Binding BillingDay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="ENGINE" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <TextBlock Text="{Binding EngineInfo}" Foreground="{StaticResource TextSecondary}" FontSize="12.5" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="Save changes" Style="{StaticResource Btn}" Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding SavedText}" Foreground="{StaticResource Success}" VerticalAlignment="Center" Margin="14,0,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
