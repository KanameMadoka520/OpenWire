<UserControl x:Class="OpenWire.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="{StaticResource L.Set.Title}" Style="{StaticResource H1}" Margin="0,0,0,14" />
            <Path Data="{StaticResource DoodleGear}" Style="{StaticResource Doodle}" Width="26" Height="26" VerticalAlignment="Center" Margin="12,0,0,10" />
        </StackPanel>

        <!-- sketchbook doodles on the empty right margin -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,60,0" IsHitTestVisible="False">
            <Path Data="{StaticResource DoodleCompass}" Style="{StaticResource DoodleHero}" Width="160" Height="160" HorizontalAlignment="Center" />
            <Path Data="{StaticResource DoodleSquiggle}" Style="{StaticResource Doodle}" Width="120" Height="20" HorizontalAlignment="Center" Margin="0,10,0,0" />
            <Path Data="{StaticResource DoodleStar}" Style="{StaticResource DoodleFill}" Width="30" Height="30" HorizontalAlignment="Center" Margin="0,20,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                <TextBlock Text="{StaticResource L.Set.Appearance}" Style="{StaticResource TableHeaderText}" Margin="2,4,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="{StaticResource L.Set.AppearanceDesc}" />
                        <StackPanel Orientation="Horizontal" Background="{StaticResource BgSubtle}" HorizontalAlignment="Left">
                            <StackPanel.Resources>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="theme" /></Style>
                            </StackPanel.Resources>
                            <RadioButton Content="{StaticResource L.Set.ThemeMinimal}" IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter=Minimal, Mode=TwoWay}" />
                            <RadioButton Content="{StaticResource L.Set.ThemePencil}" IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter=Pencil, Mode=TwoWay}" />
                            <RadioButton Content="{StaticResource L.Set.ThemeBerryDay}" IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter=BerryDay, Mode=TwoWay}" />
                            <RadioButton Content="{StaticResource L.Set.ThemeBerryNight}" IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter=BerryNight, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{StaticResource L.Set.Language}" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="{StaticResource L.Set.LanguageDesc}" />
                        <StackPanel Orientation="Horizontal" Background="{StaticResource BgSubtle}" HorizontalAlignment="Left">
                            <StackPanel.Resources>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="lang" /></Style>
                            </StackPanel.Resources>
                            <!-- Language names are shown in their own language on purpose. -->
                            <RadioButton Content="English" IsChecked="{Binding Language, Converter={StaticResource EnumMatch}, ConverterParameter=English, Mode=TwoWay}" />
                            <RadioButton Content="简体中文 (Simplified Chinese)" IsChecked="{Binding Language, Converter={StaticResource EnumMatch}, ConverterParameter=SimplifiedChinese, Mode=TwoWay}" />
                            <RadioButton Content="繁體中文 (Traditional Chinese)" IsChecked="{Binding Language, Converter={StaticResource EnumMatch}, ConverterParameter=TraditionalChinese, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{StaticResource L.Set.SecurityMonitors}" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.MonUsageAnomalies}" IsChecked="{Binding MonitorUsageAnomalies}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.MonNewDevices}" IsChecked="{Binding MonitorNewDevices}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.MonDnsChanges}" IsChecked="{Binding MonitorDnsChanges}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.MonHostsFile}" IsChecked="{Binding MonitorHostsFile}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.MonArpSpoofing}" IsChecked="{Binding MonitorArpSpoofing}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.MonRdp}" IsChecked="{Binding MonitorRdp}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.ShowNotifications}" IsChecked="{Binding ShowNotifications}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{StaticResource L.Set.Resolution}" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.ResolveHosts}" IsChecked="{Binding ResolveHostNames}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.ResolveGeoIp}" IsChecked="{Binding ResolveGeoIp}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{StaticResource L.Set.DataPlan}" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="{StaticResource L.Set.DataPlanEnable}" IsChecked="{Binding DataPlanEnabled}" Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding DataPlanEnabled}">
                            <TextBlock Text="{StaticResource L.Set.DataPlanLimit}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="120" />
                            <TextBox Style="{StaticResource Search}" Width="120" Text="{Binding DataLimitGb}" />
                            <TextBlock Text="{StaticResource L.Set.DataPlanResetDay}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="90" Margin="24,0,0,0" />
                            <TextBox Style="{StaticResource Search}" Width="80" Text="{Binding BillingDay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{StaticResource L.Set.History}" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="{StaticResource L.Set.HistoryDesc}" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{StaticResource L.Set.HistoryKeepFor}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="120" />
                            <TextBox Style="{StaticResource Search}" Width="80" Text="{Binding HistoryRetentionDays}" />
                            <TextBlock Text="{StaticResource L.Set.HistoryDays}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{StaticResource L.Set.Integrations}" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <TextBlock Text="{StaticResource L.Set.VtTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="{StaticResource L.Set.VtDesc}" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{StaticResource L.Set.VtApiKey}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="120" />
                            <TextBox Style="{StaticResource Search}" Width="360" Text="{Binding VirusTotalApiKey, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <TextBlock Margin="120,8,0,0" FontSize="11.5" Foreground="{StaticResource TextMuted}">
                            <Hyperlink NavigateUri="https://www.virustotal.com/gui/my-apikey" RequestNavigate="OnOpenLink">
                                <Run Text="{StaticResource L.Set.VtGetKey}" />
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="{StaticResource L.Set.Engine}" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <TextBlock Text="{Binding EngineInfo}" Foreground="{StaticResource TextSecondary}" FontSize="12.5" TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="{StaticResource L.Set.About}" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="OpenWire" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{Binding AppVersion}" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Bottom" />
                        </StackPanel>
                        <TextBlock Text="{StaticResource L.Set.AboutTagline}" Foreground="{StaticResource TextSecondary}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,4,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{StaticResource L.Set.AboutAuthor}" Foreground="{StaticResource TextSecondary}" FontSize="12.5" Width="120" VerticalAlignment="Center" />
                            <TextBlock FontSize="12.5" VerticalAlignment="Center">
                                <Hyperlink NavigateUri="https://github.com/KanameMadoka520" RequestNavigate="OnOpenLink">KanameMadoka520</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="{StaticResource L.Set.AboutRepo}" Foreground="{StaticResource TextSecondary}" FontSize="12.5" Width="120" VerticalAlignment="Center" />
                            <TextBlock FontSize="12.5" VerticalAlignment="Center">
                                <Hyperlink NavigateUri="https://github.com/KanameMadoka520/OpenWire" RequestNavigate="OnOpenLink">github.com/KanameMadoka520/OpenWire</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{StaticResource L.Set.AboutLicense}" Style="{StaticResource Caption}" Margin="0,12,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="{StaticResource L.Set.SaveChanges}" Style="{StaticResource Btn}" Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding SavedText}" Foreground="{StaticResource Success}" VerticalAlignment="Center" Margin="14,0,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
