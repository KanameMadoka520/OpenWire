<UserControl x:Class="OpenWire.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="Settings" Style="{StaticResource H1}" Margin="0,0,0,14" />
            <Path Data="{StaticResource DoodleGear}" Style="{StaticResource Doodle}" Width="26" Height="26" VerticalAlignment="Center" Margin="12,0,0,10" />
        </StackPanel>

        <!-- sketchbook doodles on the empty right margin -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,60,0" IsHitTestVisible="False">
            <Path Data="{StaticResource DoodleCompass}" Style="{StaticResource DoodleHero}" Width="160" Height="160" HorizontalAlignment="Center" />
            <Path Data="{StaticResource DoodleSquiggle}" Style="{StaticResource Doodle}" Width="120" Height="20" HorizontalAlignment="Center" Margin="0,10,0,0" />
            <Path Data="{StaticResource DoodleStar}" Style="{StaticResource DoodleFill}" Width="30" Height="30" HorizontalAlignment="Center" Margin="0,20,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                <TextBlock Text="APPEARANCE" Style="{StaticResource TableHeaderText}" Margin="2,4,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="Choose the interface style. Minimal is a clean flat look; Pencil is a hand-drawn sketchbook. Switching restarts OpenWire to re-skin (the engine keeps running)." />
                        <StackPanel Orientation="Horizontal" Background="{StaticResource BgSubtle}" HorizontalAlignment="Left">
                            <StackPanel.Resources>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="theme" /></Style>
                            </StackPanel.Resources>
                            <RadioButton Content="Minimal" IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter=Minimal, Mode=TwoWay}" />
                            <RadioButton Content="Pencil sketch" IsChecked="{Binding Theme, Converter={StaticResource EnumMatch}, ConverterParameter=Pencil, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="SECURITY MONITORS" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="Usage anomalies (spikes, upload-heavy apps, new countries, odd hours)" IsChecked="{Binding MonitorUsageAnomalies}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="New device on network" IsChecked="{Binding MonitorNewDevices}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="DNS server changes" IsChecked="{Binding MonitorDnsChanges}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="Hosts file changes" IsChecked="{Binding MonitorHostsFile}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="ARP spoofing (gateway MAC changes)" IsChecked="{Binding MonitorArpSpoofing}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="Remote Desktop (RDP) connections" IsChecked="{Binding MonitorRdp}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="Show desktop notifications" IsChecked="{Binding ShowNotifications}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="RESOLUTION" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="Resolve host names (reverse DNS)" IsChecked="{Binding ResolveHostNames}" Margin="0,0,0,14" />
                        <CheckBox Style="{StaticResource Switch}" Content="Resolve countries (GeoIP)" IsChecked="{Binding ResolveGeoIp}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="DATA PLAN" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <CheckBox Style="{StaticResource Switch}" Content="Enable monthly data plan" IsChecked="{Binding DataPlanEnabled}" Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding DataPlanEnabled}">
                            <TextBlock Text="Limit (GB)" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="120" />
                            <TextBox Style="{StaticResource Search}" Width="120" Text="{Binding DataLimitGb}" />
                            <TextBlock Text="Reset day" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="90" Margin="24,0,0,0" />
                            <TextBox Style="{StaticResource Search}" Width="80" Text="{Binding BillingDay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="HISTORY" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="Per-minute history is pruned after this many days to keep the database small; compact daily rollups are kept much longer for long-term trends and anomaly baselines. Set to 0 to keep all minute-level history." />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Keep minutes for" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="120" />
                            <TextBox Style="{StaticResource Search}" Width="80" Text="{Binding HistoryRetentionDays}" />
                            <TextBlock Text="days" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="INTEGRATIONS" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <StackPanel>
                        <TextBlock Text="VirusTotal file reputation" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="Optional. Paste your own free VirusTotal API key to show a per-app reputation column on the Firewall screen. OpenWire hashes each application binary and looks the digest up — the file itself is never uploaded. Leave empty to disable." />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="API key" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Width="120" />
                            <TextBox Style="{StaticResource Search}" Width="360" Text="{Binding VirusTotalApiKey, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <TextBlock Margin="120,8,0,0" FontSize="11.5" Foreground="{StaticResource TextMuted}">
                            <Hyperlink NavigateUri="https://www.virustotal.com/gui/my-apikey" RequestNavigate="OnOpenLink">
                                Get a free key at virustotal.com
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="ENGINE" Style="{StaticResource TableHeaderText}" Margin="2,24,0,10" />
                <Border Style="{StaticResource Card}" Padding="18">
                    <TextBlock Text="{Binding EngineInfo}" Foreground="{StaticResource TextSecondary}" FontSize="12.5" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="Save changes" Style="{StaticResource Btn}" Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding SavedText}" Foreground="{StaticResource Success}" VerticalAlignment="Center" Margin="14,0,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
