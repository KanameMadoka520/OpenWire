<Window x:Class="OpenWire.App.Views.RenameDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenWire" Width="380" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgApp}" FontFamily="{StaticResource UiFont}">
    <Border Padding="24" Background="{StaticResource BgApp}">
        <StackPanel>
            <TextBlock Text="{StaticResource L.Scan.RenameDevice}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{StaticResource L.Scan.RenameLabel}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6" />
            <TextBox x:Name="NameBox" Style="{StaticResource Search}" MaxLength="64" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="{StaticResource L.Common.Cancel}" Style="{StaticResource BtnGhost}" IsCancel="True" Margin="0,0,10,0" MinWidth="90" />
                <Button Content="{StaticResource L.Common.Apply}" Style="{StaticResource Btn}" Click="OnOk" IsDefault="True" MinWidth="90" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
