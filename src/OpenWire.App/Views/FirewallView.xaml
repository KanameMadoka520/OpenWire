<UserControl x:Class="OpenWire.App.Views.FirewallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             xmlns:models="clr-namespace:OpenWire.Core.Models;assembly=OpenWire.Core"
             d:DataContext="{d:DesignInstance vm:FirewallViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Firewall" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Mode" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Orientation="Horizontal" Background="{StaticResource BgSubtle}">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="fwmode" /></Style>
                    </StackPanel.Resources>
                    <RadioButton Content="Off" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.Off}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=Off, Mode=OneWay}" />
                    <RadioButton Content="Click to block" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.ClickToBlock}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=ClickToBlock, Mode=OneWay}" />
                    <RadioButton Content="Ask to connect" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.AskToConnect}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=AskToConnect, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,9" Margin="0,14,0,10" Background="{StaticResource BlockBg}" BorderThickness="0"
                Visibility="{Binding CanEnforce, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <TextBlock Text="⚠  The engine is not running elevated — blocks can't be enforced and per-app rates are unavailable. Start OpenWire.Service as administrator."
                       Foreground="{StaticResource BlockText}" FontSize="12" TextWrapping="Wrap" />
        </Border>

        <!-- column header -->
        <Grid Grid.Row="2" Margin="0,6,16,0" Height="34">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="132" />
                <ColumnDefinition Width="132" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="92" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="APPLICATION" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="INCOMING" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="OUTGOING" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="4" Text="VERSION" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="5" Text="HOST" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="6" Text="↓" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="7" Text="↑" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Apps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <!-- app row -->
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="0,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="132" />
                                        <ColumnDefinition Width="132" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="92" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.Column="0" IsChecked="{Binding IsExpanded, Mode=TwoWay}" Cursor="Hand"
                                                  Visibility="{Binding HasChildren, Converter={StaticResource BoolVis}}" Background="Transparent" BorderThickness="0">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock x:Name="chev" Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="chev" Property="Text" Value="&#xE70D;" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Width="18" Height="18" Margin="0,0,10,0" Source="{Binding Path, Converter={StaticResource AppIcon}}" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <ToggleButton Grid.Column="2" Style="{StaticResource Pill}" IsChecked="{Binding BlockIn, Mode=TwoWay}" Command="{Binding ToggleInCommand}" VerticalAlignment="Center" />
                                    <ToggleButton Grid.Column="3" Style="{StaticResource Pill}" IsChecked="{Binding BlockOut, Mode=TwoWay}" Command="{Binding ToggleOutCommand}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding Version}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="5" Text="{Binding HostText}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="6" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource InLine}" Text="{Binding DownText}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="7" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource OutLine}" Text="{Binding UpText}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <!-- child processes -->
                            <ItemsControl ItemsSource="{Binding Processes}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}" Background="{StaticResource BgSubtle}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="30">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="132" />
                                                <ColumnDefinition Width="132" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="92" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Margin="40,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="12">
                                                <Run Text="PID" /><Run Text=" " /><Run Text="{Binding Pid, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="6" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource InLine}" Text="{Binding DownText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="7" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource OutLine}" Text="{Binding UpText}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
