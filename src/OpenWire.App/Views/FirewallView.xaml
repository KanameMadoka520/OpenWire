<UserControl x:Class="OpenWire.App.Views.FirewallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             xmlns:models="clr-namespace:OpenWire.Core.Models;assembly=OpenWire.Core"
             d:DataContext="{d:DesignInstance vm:FirewallViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Firewall" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Mode" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Orientation="Horizontal" Background="{StaticResource BgSubtle}">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="fwmode" /></Style>
                    </StackPanel.Resources>
                    <RadioButton Content="Off" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.Off}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=Off, Mode=OneWay}" />
                    <RadioButton Content="Click to block" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.ClickToBlock}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=ClickToBlock, Mode=OneWay}" />
                    <RadioButton Content="Ask to connect" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.AskToConnect}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=AskToConnect, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,9" Margin="0,14,0,14" Background="{StaticResource BlockBg}" BorderThickness="0"
                Visibility="{Binding CanEnforce, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <TextBlock Text="⚠  The engine is not running elevated — blocks cannot be enforced. Start OpenWire.Service as administrator."
                       Foreground="{StaticResource BlockText}" FontSize="12" />
        </Border>

        <ListView Grid.Row="2" Style="{StaticResource Table}" ItemContainerStyle="{StaticResource Row}" ItemsSource="{Binding Apps}" Margin="0,10,0,0">
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource ColHeader}">
                    <GridViewColumn Header="APPLICATION" Width="300">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Image Width="18" Height="18" Margin="0,0,10,0" Source="{Binding Path, Converter={StaticResource AppIcon}}" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="INCOMING" Width="140">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <ToggleButton Style="{StaticResource Pill}" IsChecked="{Binding BlockIn, Mode=TwoWay}" Command="{Binding ToggleInCommand}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="OUTGOING" Width="140">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <ToggleButton Style="{StaticResource Pill}" IsChecked="{Binding BlockOut, Mode=TwoWay}" Command="{Binding ToggleOutCommand}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="VERSION" Width="120">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Text="{Binding Version}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="HOSTS" Width="110">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Text="{Binding HostText}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="DOWN" Width="100">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource InLine}" Text="{Binding DownText}" VerticalAlignment="Center" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="UP" Width="100">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource OutLine}" Text="{Binding UpText}" VerticalAlignment="Center" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
