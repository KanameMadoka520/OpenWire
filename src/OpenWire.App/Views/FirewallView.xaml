<UserControl x:Class="OpenWire.App.Views.FirewallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             xmlns:ctrl="clr-namespace:OpenWire.App.Controls"
             xmlns:models="clr-namespace:OpenWire.Core.Models;assembly=OpenWire.Core"
             d:DataContext="{d:DesignInstance vm:FirewallViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{StaticResource L.Fw.Title}" Style="{StaticResource H1}" />
                    <Path Data="{StaticResource DoodleShield}" Style="{StaticResource Doodle}" Width="24" Height="24" VerticalAlignment="Center" Margin="12,2,0,0" />
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{StaticResource L.Fw.Mode}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Orientation="Horizontal" Background="{StaticResource BgSubtle}">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="fwmode" /></Style>
                    </StackPanel.Resources>
                    <RadioButton Content="{StaticResource L.Fw.ModeOff}" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.Off}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=Off, Mode=OneWay}" />
                    <RadioButton Content="{StaticResource L.Fw.ModeClickToBlock}" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.ClickToBlock}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=ClickToBlock, Mode=OneWay}" />
                    <RadioButton Content="{StaticResource L.Fw.ModeAskToConnect}" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.AskToConnect}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=AskToConnect, Mode=OneWay}" />
                </StackPanel>
                <Button Style="{StaticResource BtnGhost}" Margin="12,0,0,0" Padding="12,6" Command="{Binding ToggleLockdownCommand}"
                        IsEnabled="{Binding CanEnforce}" ToolTip="{StaticResource L.Fw.LockdownTip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,7,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LockdownActive}" Value="True"><Setter Property="Foreground" Value="{StaticResource Danger}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{StaticResource L.Fw.Lockdown}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LockdownActive}" Value="True">
                                            <Setter Property="Text" Value="{StaticResource L.Fw.LockdownOn}" />
                                            <Setter Property="Foreground" Value="{StaticResource Danger}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
                <Button x:Name="PanicButton" Style="{StaticResource IconBtn}" Content="&#xE916;" Margin="4,0,0,0"
                        ToolTip="{StaticResource L.Fw.PanicTip}" IsEnabled="{Binding CanEnforce}" Click="OnPanicMenu">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{StaticResource L.Fw.Panic15}" CommandParameter="15"
                                      Command="{Binding PlacementTarget.DataContext.PanicForCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="{StaticResource L.Fw.Panic60}" CommandParameter="60"
                                      Command="{Binding PlacementTarget.DataContext.PanicForCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="{StaticResource L.Fw.Panic480}" CommandParameter="480"
                                      Command="{Binding PlacementTarget.DataContext.PanicForCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Non-elevated warning (own row; collapses to zero height when elevated) -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,9" Margin="0,12,0,2" Background="{StaticResource BlockBg}" BorderThickness="0"
                Visibility="{Binding CanEnforce, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <TextBlock Text="{StaticResource L.Fw.NotElevated}"
                       Foreground="{StaticResource BlockText}" FontSize="12" TextWrapping="Wrap" />
        </Border>

        <!-- Lock-down banner (own row; mutually exclusive with the non-elevated warning above) -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,9" Margin="0,12,0,2" Background="{StaticResource Danger}" BorderThickness="0"
                Visibility="{Binding LockdownActive, Converter={StaticResource BoolVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Text="{StaticResource L.Fw.LockdownBanner}" Foreground="White" FontSize="12.5" TextWrapping="Wrap" VerticalAlignment="Center" />
                <TextBlock Text="{Binding LockdownUntilText}" Foreground="White" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center" Margin="6,0,0,0"
                           Visibility="{Binding LockdownUntilText.Length, Converter={StaticResource ZeroVis}}" />
            </StackPanel>
        </Border>

        <!-- Profile bar -->
        <Grid Grid.Row="2" Margin="0,14,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE912;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{StaticResource L.Fw.Profile}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox MinWidth="150" VerticalAlignment="Center" ItemsSource="{Binding Profiles}"
                          DisplayMemberPath="Name" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}" />
                <Button Style="{StaticResource IconBtn}" Content="&#xE710;" ToolTip="{StaticResource L.Fw.NewProfileTip}"
                        Command="{Binding NewProfileCommand}" Margin="6,0,0,0" />
                <Button Style="{StaticResource IconBtn}" Content="&#xE74D;" ToolTip="{StaticResource L.Fw.DeleteProfileTip}"
                        Command="{Binding DeleteProfileCommand}" />
                <Border Background="{StaticResource BgSubtle}" CornerRadius="4" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding NetworkName.Length, Converter={StaticResource ZeroVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE701;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding NetworkName}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <Grid Width="240" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBox Style="{StaticResource Search}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="{StaticResource L.Fw.SearchApps}" Foreground="{StaticResource TextMuted}" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                           Visibility="{Binding SearchText.Length, Converter={StaticResource ZeroVis}, ConverterParameter=invert}" />
            </Grid>
        </Grid>

        <!-- Blocklist subscriptions (collapsible): community host lists matched against live
             connections. Detection alerts by default; blocking only via the explicit switch. -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,4">
            <StackPanel>
                <Grid Margin="14,9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ToggleButton Grid.Column="0" IsChecked="{Binding BlocklistsExpanded, Mode=TwoWay}" Cursor="Hand"
                                  Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Margin="0,0,10,0" Width="18">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <TextBlock x:Name="chev" Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="chev" Property="Text" Value="&#xE70D;" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{StaticResource L.Fw.Blocklists}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="{Binding BlocklistSummary}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{StaticResource L.Fw.BlocklistRefreshing}" Style="{StaticResource Caption}"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               Visibility="{Binding BlocklistRefreshing, Converter={StaticResource BoolVis}}" />
                    <CheckBox Grid.Column="3" Style="{StaticResource Switch}" Content="{StaticResource L.Fw.BlocklistEnforce}"
                              ToolTip="{StaticResource L.Fw.BlocklistEnforceTip}" IsEnabled="{Binding CanEnforce}"
                              IsChecked="{Binding BlocklistEnforce, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button Grid.Column="4" Style="{StaticResource IconBtn}" Content="&#xE72C;" ToolTip="{StaticResource L.Fw.BlocklistRefreshTip}"
                            Command="{Binding RefreshBlocklistsCommand}" VerticalAlignment="Center" />
                </Grid>
                <StackPanel Visibility="{Binding BlocklistsExpanded, Converter={StaticResource BoolVis}}" Margin="14,0,14,12">
                    <ItemsControl ItemsSource="{Binding Blocklists}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="34" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" Style="{StaticResource Switch}" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                  Command="{Binding ToggleCommand}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Url}" Foreground="{StaticResource TextMuted}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                                   Text="{Binding EntryCountText}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Foreground="{StaticResource TextMuted}" FontSize="12"
                                                   Text="{Binding LastFetchText}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{StaticResource Warning}" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   ToolTip="{Binding LastError}"
                                                   Visibility="{Binding HasError, Converter={StaticResource BoolVis}}" />
                                        <Button Grid.Column="5" Style="{StaticResource IconBtn}" Content="&#xE74D;" ToolTip="{StaticResource L.Fw.BlocklistRemoveTip}"
                                                Command="{Binding RemoveCommand}" VerticalAlignment="Center"
                                                Visibility="{Binding IsPreset, Converter={StaticResource BoolVis}, ConverterParameter=invert}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox Style="{StaticResource Search}" Text="{Binding NewListName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{StaticResource L.Fw.BlocklistNameHint}" Foreground="{StaticResource TextMuted}" FontSize="13"
                                       Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="{Binding NewListName.Length, Converter={StaticResource ZeroVis}, ConverterParameter=invert}" />
                        </Grid>
                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <TextBox Style="{StaticResource Search}" Text="{Binding NewListUrl, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{StaticResource L.Fw.BlocklistUrlHint}" Foreground="{StaticResource TextMuted}" FontSize="13"
                                       Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="{Binding NewListUrl.Length, Converter={StaticResource ZeroVis}, ConverterParameter=invert}" />
                        </Grid>
                        <Button Grid.Column="2" Style="{StaticResource BtnGhost}" Padding="12,6" Margin="8,0,0,0"
                                Content="{StaticResource L.Fw.BlocklistAdd}" Command="{Binding AddBlocklistCommand}" />
                    </Grid>
                    <TextBlock Text="{StaticResource L.Fw.BlocklistHint}" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Header + rows share one column layout and one horizontal scrollbar:
             the content tracks the viewport width but never shrinks below MinWidth,
             so on a narrow window it scrolls sideways instead of columns colliding. -->
        <ScrollViewer x:Name="HScroll" Grid.Row="4" Margin="0,6,0,0"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <Grid Width="{Binding ViewportWidth, ElementName=HScroll}" MinWidth="1096">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- column header -->
                <Grid Grid.Row="0" Margin="0,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="116" />
                        <ColumnDefinition Width="116" />
                        <ColumnDefinition Width="76" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="66" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="96" />
                    </Grid.ColumnDefinitions>
                    <!-- Clickable sort headers: label + a ▲/▼ arrow on the active column. -->
                    <Grid.Resources>
                        <Style x:Key="HdrText" TargetType="TextBlock" BasedOn="{StaticResource TableHeaderText}" />
                    </Grid.Resources>
                    <Button Grid.Column="1" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="name">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Fw.ColApplication}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="name"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="in">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Fw.ColIncoming}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="in"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="out">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Fw.ColOutgoing}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="out"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="4" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="version">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Fw.ColVersion}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="version"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="5" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="host">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Fw.ColHost}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="host"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="6" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="vt">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Fw.ColVirusTotal}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="vt"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="7" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="trend">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Fw.ColTrend}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="trend"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="8" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="down">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="↓" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="down"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="9" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="up">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="↑" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="up"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <TextBlock Grid.Column="10" Style="{StaticResource HdrText}" Text="{StaticResource L.Fw.ColQuota}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </Grid>

                <!-- Rows: a ListBox virtualizes + recycles containers, so only the
                     ~15 visible rows of the (often 150+) app list are ever realized. -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Apps}" Background="Transparent" BorderThickness="0" Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                        <StackPanel>
                            <!-- app row -->
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="0,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" MinWidth="150" />
                                        <ColumnDefinition Width="116" />
                                        <ColumnDefinition Width="116" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="66" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.Column="0" IsChecked="{Binding IsExpanded, Mode=TwoWay}" Cursor="Hand"
                                                  Visibility="{Binding HasChildren, Converter={StaticResource BoolVis}}" Background="Transparent" BorderThickness="0">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock x:Name="chev" Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="chev" Property="Text" Value="&#xE70D;" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Width="18" Height="18" Margin="0,0,10,0" Source="{Binding Path, Converter={StaticResource AppIcon}}" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <ToggleButton Grid.Column="2" Style="{StaticResource Pill}" IsChecked="{Binding BlockIn, Mode=TwoWay}" Command="{Binding ToggleInCommand}" VerticalAlignment="Center" />
                                    <ToggleButton Grid.Column="3" Style="{StaticResource Pill}" IsChecked="{Binding BlockOut, Mode=TwoWay}" Command="{Binding ToggleOutCommand}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding Version}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Width="16" Height="11" Margin="0,0,7,0" VerticalAlignment="Center"
                                               Source="{Binding HostCountry, Converter={StaticResource Flag}}" />
                                        <TextBlock Text="{Binding HostText}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="6" Text="{Binding ReputationText}" ToolTip="{Binding ReputationTip}" FontSize="11.5" VerticalAlignment="Center"
                                               Foreground="{Binding RepState, Converter={StaticResource RepBrush}}" TextTrimming="CharacterEllipsis" />
                                    <ctrl:Sparkline Grid.Column="7" Values="{Binding Spark}" Height="20" Width="56" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="8" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource InLine}" Text="{Binding DownText}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="9" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource OutLine}" Text="{Binding UpText}" VerticalAlignment="Center" />
                                    <!-- Data quota: click to set/edit. Amber when the app has reached its cap. -->
                                    <Button Grid.Column="10" Style="{StaticResource SortHeaderBtn}" Command="{Binding EditQuotaCommand}"
                                            HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="{StaticResource L.Fw.QuotaEditTip}" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{StaticResource Warning}" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Visibility="{Binding QuotaOver, Converter={StaticResource BoolVis}}" />
                                            <TextBlock Text="{Binding QuotaText}" FontSize="11.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasQuota}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding QuotaOver}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Warning}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                            <!-- child processes -->
                            <ItemsControl ItemsSource="{Binding Processes}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}" Background="{StaticResource BgSubtle}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="30">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="*" MinWidth="150" />
                                                <ColumnDefinition Width="116" />
                                                <ColumnDefinition Width="116" />
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="78" />
                                                <ColumnDefinition Width="66" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="96" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Margin="40,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="12">
                                                <Run Text="{StaticResource L.Fw.Pid}" /><Run Text=" " /><Run Text="{Binding Pid, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="8" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource InLine}" Text="{Binding DownText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="9" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource OutLine}" Text="{Binding UpText}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
