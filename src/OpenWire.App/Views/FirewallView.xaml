<UserControl x:Class="OpenWire.App.Views.FirewallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             xmlns:ctrl="clr-namespace:OpenWire.App.Controls"
             xmlns:models="clr-namespace:OpenWire.Core.Models;assembly=OpenWire.Core"
             d:DataContext="{d:DesignInstance vm:FirewallViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{StaticResource L.Fw.Title}" Style="{StaticResource H1}" />
                    <Path Data="{StaticResource DoodleShield}" Style="{StaticResource Doodle}" Width="24" Height="24" VerticalAlignment="Center" Margin="12,2,0,0" />
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{StaticResource L.Fw.Mode}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Orientation="Horizontal" Background="{StaticResource BgSubtle}">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="fwmode" /></Style>
                    </StackPanel.Resources>
                    <RadioButton Content="{StaticResource L.Fw.ModeOff}" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.Off}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=Off, Mode=OneWay}" />
                    <RadioButton Content="{StaticResource L.Fw.ModeClickToBlock}" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.ClickToBlock}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=ClickToBlock, Mode=OneWay}" />
                    <RadioButton Content="{StaticResource L.Fw.ModeAskToConnect}" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.AskToConnect}"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=AskToConnect, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Non-elevated warning (own row; collapses to zero height when elevated) -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,9" Margin="0,12,0,2" Background="{StaticResource BlockBg}" BorderThickness="0"
                Visibility="{Binding CanEnforce, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <TextBlock Text="{StaticResource L.Fw.NotElevated}"
                       Foreground="{StaticResource BlockText}" FontSize="12" TextWrapping="Wrap" />
        </Border>

        <!-- Profile bar -->
        <Grid Grid.Row="2" Margin="0,14,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE912;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{StaticResource L.Fw.Profile}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox MinWidth="150" VerticalAlignment="Center" ItemsSource="{Binding Profiles}"
                          DisplayMemberPath="Name" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}" />
                <Button Style="{StaticResource IconBtn}" Content="&#xE710;" ToolTip="{StaticResource L.Fw.NewProfileTip}"
                        Command="{Binding NewProfileCommand}" Margin="6,0,0,0" />
                <Button Style="{StaticResource IconBtn}" Content="&#xE74D;" ToolTip="{StaticResource L.Fw.DeleteProfileTip}"
                        Command="{Binding DeleteProfileCommand}" />
                <Border Background="{StaticResource BgSubtle}" CornerRadius="4" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding NetworkName.Length, Converter={StaticResource ZeroVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE701;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding NetworkName}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <Grid Width="240" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBox Style="{StaticResource Search}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="{StaticResource L.Fw.SearchApps}" Foreground="{StaticResource TextMuted}" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                           Visibility="{Binding SearchText.Length, Converter={StaticResource ZeroVis}, ConverterParameter=invert}" />
            </Grid>
        </Grid>

        <!-- Header + rows share one column layout and one horizontal scrollbar:
             the content tracks the viewport width but never shrinks below MinWidth,
             so on a narrow window it scrolls sideways instead of columns colliding. -->
        <ScrollViewer x:Name="HScroll" Grid.Row="3" Margin="0,6,0,0"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <Grid Width="{Binding ViewportWidth, ElementName=HScroll}" MinWidth="1000">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- column header -->
                <Grid Grid.Row="0" Margin="0,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="116" />
                        <ColumnDefinition Width="116" />
                        <ColumnDefinition Width="76" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="66" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="{StaticResource L.Fw.ColApplication}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{StaticResource L.Fw.ColIncoming}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{StaticResource L.Fw.ColOutgoing}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="{StaticResource L.Fw.ColVersion}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="5" Text="{StaticResource L.Fw.ColHost}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="6" Text="{StaticResource L.Fw.ColVirusTotal}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="7" Text="{StaticResource L.Fw.ColTrend}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="8" Text="↓" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="9" Text="↑" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                </Grid>

                <!-- Rows: a ListBox virtualizes + recycles containers, so only the
                     ~15 visible rows of the (often 150+) app list are ever realized. -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Apps}" Background="Transparent" BorderThickness="0" Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                        <StackPanel>
                            <!-- app row -->
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="0,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" MinWidth="150" />
                                        <ColumnDefinition Width="116" />
                                        <ColumnDefinition Width="116" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="66" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.Column="0" IsChecked="{Binding IsExpanded, Mode=TwoWay}" Cursor="Hand"
                                                  Visibility="{Binding HasChildren, Converter={StaticResource BoolVis}}" Background="Transparent" BorderThickness="0">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock x:Name="chev" Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="chev" Property="Text" Value="&#xE70D;" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Width="18" Height="18" Margin="0,0,10,0" Source="{Binding Path, Converter={StaticResource AppIcon}}" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <ToggleButton Grid.Column="2" Style="{StaticResource Pill}" IsChecked="{Binding BlockIn, Mode=TwoWay}" Command="{Binding ToggleInCommand}" VerticalAlignment="Center" />
                                    <ToggleButton Grid.Column="3" Style="{StaticResource Pill}" IsChecked="{Binding BlockOut, Mode=TwoWay}" Command="{Binding ToggleOutCommand}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding Version}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Width="16" Height="11" Margin="0,0,7,0" VerticalAlignment="Center"
                                               Source="{Binding HostCountry, Converter={StaticResource Flag}}" />
                                        <TextBlock Text="{Binding HostText}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="6" Text="{Binding ReputationText}" ToolTip="{Binding ReputationTip}" FontSize="11.5" VerticalAlignment="Center"
                                               Foreground="{Binding RepState, Converter={StaticResource RepBrush}}" TextTrimming="CharacterEllipsis" />
                                    <ctrl:Sparkline Grid.Column="7" Values="{Binding Spark}" Height="20" Width="56" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="8" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource InLine}" Text="{Binding DownText}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="9" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource OutLine}" Text="{Binding UpText}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <!-- child processes -->
                            <ItemsControl ItemsSource="{Binding Processes}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}" Background="{StaticResource BgSubtle}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="30">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="*" MinWidth="150" />
                                                <ColumnDefinition Width="116" />
                                                <ColumnDefinition Width="116" />
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="78" />
                                                <ColumnDefinition Width="66" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Margin="40,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="12">
                                                <Run Text="{StaticResource L.Fw.Pid}" /><Run Text=" " /><Run Text="{Binding Pid, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="8" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource InLine}" Text="{Binding DownText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="9" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource OutLine}" Text="{Binding UpText}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
