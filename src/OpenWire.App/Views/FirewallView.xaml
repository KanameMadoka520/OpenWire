<UserControl x:Class="OpenWire.App.Views.FirewallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             xmlns:models="clr-namespace:OpenWire.Core.Models;assembly=OpenWire.Core"
             d:DataContext="{d:DesignInstance vm:FirewallViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header + mode selector -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Firewall" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="{StaticResource BgPanel}">
                <StackPanel.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}">
                        <Setter Property="GroupName" Value="fwmode" />
                    </Style>
                </StackPanel.Resources>
                <RadioButton Content="Off" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.Off}"
                             IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=Off, Mode=OneWay}" />
                <RadioButton Content="Click to block" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.ClickToBlock}"
                             IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=ClickToBlock, Mode=OneWay}" />
                <RadioButton Content="Ask to connect" Command="{Binding SetModeCommand}" CommandParameter="{x:Static models:FirewallMode.AskToConnect}"
                             IsChecked="{Binding Mode, Converter={StaticResource EnumMatch}, ConverterParameter=AskToConnect, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,8" Margin="0,14,0,14"
                Visibility="{Binding CanEnforce, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <TextBlock Text="⚠  The engine is not running elevated — blocks cannot be enforced. Start OpenWire.Service as administrator."
                       Foreground="{StaticResource Warning}" FontSize="12" />
        </Border>

        <!-- App table -->
        <ListView Grid.Row="2" Style="{StaticResource Table}" ItemContainerStyle="{StaticResource Row}"
                  ItemsSource="{Binding Apps}">
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource ColHeader}">
                    <GridViewColumn Header="" Width="48">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding ToggleBlockCommand}" Cursor="Hand" ToolTip="Block / allow"
                                        Background="Transparent" BorderThickness="0" Width="30" Height="30">
                                    <TextBlock Text="&#xE83D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15"
                                               Foreground="{Binding Status, Converter={StaticResource FwBrush}}" />
                                </Button>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="APPLICATION" Width="300">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="18" Height="18" Margin="0,0,10,0"
                                           Source="{Binding Path, Converter={StaticResource AppIcon}}" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="PUBLISHER" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Publisher}" Foreground="{StaticResource TextSecondary}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="DOWN" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource Mono}" Foreground="{StaticResource InLine}" Text="{Binding DownText}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="UP" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource Mono}" Foreground="{StaticResource OutLine}" Text="{Binding UpText}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="STATUS" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold"
                                           Foreground="{Binding Status, Converter={StaticResource FwBrush}}"
                                           Text="{Binding Status}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
