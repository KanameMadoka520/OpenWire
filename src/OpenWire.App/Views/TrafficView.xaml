<UserControl x:Class="OpenWire.App.Views.TrafficView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:OpenWire.App.Controls"
             xmlns:views="clr-namespace:OpenWire.App.Views"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:TrafficViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <UserControl.Resources>
        <!-- "+N more" link that opens the overflow popup -->
        <Style x:Key="MoreLink" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.75" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Overflow popup card (shared look for the "show all" floats) -->
        <Style x:Key="OverflowCard" TargetType="Border">
            <Setter Property="Margin" Value="10" />
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource CtlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource CtlCorner}" />
            <Setter Property="Effect">
                <Setter.Value><DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="3" Direction="270" Opacity="0.3" /></Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="OverflowAppTemplate">
            <Grid Margin="14,6">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Image Grid.Column="0" Width="16" Height="16" Margin="0,0,9,0" VerticalAlignment="Center" Source="{Binding App.ExecutablePath, Converter={StaticResource AppIcon}}" />
                <TextBlock Grid.Column="1" Text="{Binding App.Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="10,0,0,0"
                           Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="OverflowHostTemplate">
            <Grid Margin="14,6">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Image Grid.Column="0" Width="16" Height="11" Margin="0,0,8,0" VerticalAlignment="Center" Source="{Binding Geo.CountryCode, Converter={StaticResource Flag}}" />
                <TextBlock Grid.Column="1" Text="{Binding Host}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="10,0,0,0"
                           Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Control strip -->
        <Grid Grid.Row="0" Margin="24,16,24,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="FilterBtn" Style="{StaticResource IconBtn}" VerticalAlignment="Center"
                        Content="&#xE71C;" ToolTip="{StaticResource L.Traffic.Filter}" Click="OnToggleFilter" />
                <Button x:Name="PauseBtn" Style="{StaticResource IconBtn}" VerticalAlignment="Center" Margin="6,0,0,0"
                        Content="&#xE769;" ToolTip="{StaticResource L.Traffic.PauseLiveGraph}" Click="OnTogglePause" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Background="{StaticResource BgSubtle}">
                <StackPanel.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="subview" /></Style>
                </StackPanel.Resources>
                <RadioButton Padding="16,7" AutomationProperties.Name="GraphView" ToolTip="{StaticResource L.Traffic.TrafficGraph}" IsChecked="{Binding SubView, Converter={StaticResource EnumMatch}, ConverterParameter=Graph, Mode=TwoWay}">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" />
                </RadioButton>
                <RadioButton Padding="16,7" AutomationProperties.Name="ColumnsView" ToolTip="{StaticResource L.Traffic.NetworkUsage}" IsChecked="{Binding SubView, Converter={StaticResource EnumMatch}, ConverterParameter=Columns, Mode=TwoWay}">
                    <TextBlock Text="&#xE8A9;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" />
                </RadioButton>
                <RadioButton Padding="16,7" AutomationProperties.Name="MapView" ToolTip="{StaticResource L.Traffic.WorldMap}" IsChecked="{Binding SubView, Converter={StaticResource EnumMatch}, ConverterParameter=Map, Mode=TwoWay}">
                    <TextBlock Text="&#xE909;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" />
                </RadioButton>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Background="{StaticResource BgSubtle}">
                <StackPanel.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="trange" /></Style>
                </StackPanel.Resources>
                <RadioButton Content="{StaticResource L.Traffic.Range5Min}" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=FiveMinutes, Mode=TwoWay}" />
                <RadioButton Content="{StaticResource L.Traffic.Range3Hours}" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=ThreeHours, Mode=TwoWay}" />
                <RadioButton Content="{StaticResource L.Traffic.Range24Hours}" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Day, Mode=TwoWay}" />
                <RadioButton Content="{StaticResource L.Traffic.RangeWeek}" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Week, Mode=TwoWay}" />
                <RadioButton Content="{StaticResource L.Traffic.RangeMonth}" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Month, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <!-- Sub-views (with the collapsible filter panel on the left) -->
        <Grid Grid.Row="1" Margin="24,0,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <views:FilterPanel x:Name="Filter" Grid.Column="0" Width="360" Margin="0,0,12,0"
                               Visibility="Collapsed" DataContext="{Binding Usage}" />

            <Grid Grid.Column="1">
            <!-- graph -->
            <Border Background="{StaticResource BgGraph}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8"
                    ClipToBounds="True" Visibility="{Binding SubView, Converter={StaticResource EnumVis}, ConverterParameter=Graph}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ctrl:TrafficGraph x:Name="Graph" Grid.Row="0" />
                    <!-- breakdown bar: down/up totals + top app + top host for the view (or the drag-selected band) -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,7" Background="{StaticResource BgPanel}">
                        <Grid>
                        <!-- currently-visible time window (or the drag-selected band's range) -->
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource Mono}"
                                   FontSize="12" Foreground="{StaticResource TextSecondary}" Text="{Binding RangeLabel}" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource InLine}" VerticalAlignment="Center" />
                            <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding BreakdownDown}" />
                            <TextBlock Text="&#xE74A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource OutLine}" VerticalAlignment="Center" Margin="16,0,0,0" />
                            <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding BreakdownUp}" />
                            <!-- app + host detail: hidden while a band is drag-selected, since the "+N more"
                                 popups bind the whole-view lists and would disagree with the band's totals -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding BandActive, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                            <Border Width="1" Background="{StaticResource Border}" Margin="16,2,16,2" />

                            <!-- top app + "+N more" popup -->
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center" Text="{Binding TopAppName}" TextTrimming="CharacterEllipsis" MaxWidth="220" />
                            <Button x:Name="MoreAppsBtn" Style="{StaticResource MoreLink}" Margin="4,0,0,0" Content="{Binding MoreAppsText}"
                                    Visibility="{Binding HasMoreApps, Converter={StaticResource BoolVis}}" Click="OnShowAllApps" />
                            <Popup x:Name="AppsPopup" PlacementTarget="{Binding ElementName=MoreAppsBtn}" Placement="Top"
                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="-2">
                                <Border Style="{StaticResource OverflowCard}" Width="360">
                                    <DockPanel>
                                        <Grid DockPanel.Dock="Top" Margin="14,12,8,6">
                                            <TextBlock Text="{StaticResource L.Traffic.AllApps}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                                            <Button HorizontalAlignment="Right" Style="{StaticResource IconBtn}" Width="30" Height="28"
                                                    Content="&#xE711;" ToolTip="{StaticResource L.Common.Close}" Click="OnCloseApps" />
                                        </Grid>
                                        <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                                            <ItemsControl ItemsSource="{Binding Usage.Apps}" ItemTemplate="{StaticResource OverflowAppTemplate}" />
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </Popup>

                            <Border Width="1" Background="{StaticResource Border}" Margin="16,2,16,2" />

                            <!-- top host + "+N more" popup -->
                            <TextBlock Text="&#xE968;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center" Text="{Binding TopHostName}" TextTrimming="CharacterEllipsis" MaxWidth="220" />
                            <Button x:Name="MoreHostsBtn" Style="{StaticResource MoreLink}" Margin="4,0,0,0" Content="{Binding MoreHostsText}"
                                    Visibility="{Binding HasMoreHosts, Converter={StaticResource BoolVis}}" Click="OnShowAllHosts" />
                            <Popup x:Name="HostsPopup" PlacementTarget="{Binding ElementName=MoreHostsBtn}" Placement="Top"
                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="-2">
                                <Border Style="{StaticResource OverflowCard}" Width="380">
                                    <DockPanel>
                                        <Grid DockPanel.Dock="Top" Margin="14,12,8,6">
                                            <TextBlock Text="{StaticResource L.Traffic.AllHosts}" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                                            <Button HorizontalAlignment="Right" Style="{StaticResource IconBtn}" Width="30" Height="28"
                                                    Content="&#xE711;" ToolTip="{StaticResource L.Common.Close}" Click="OnCloseHosts" />
                                        </Grid>
                                        <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                                            <ItemsControl ItemsSource="{Binding Usage.Hosts}" ItemTemplate="{StaticResource OverflowHostTemplate}" />
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </Popup>
                            </StackPanel>
                        </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- columns (usage) -->
            <views:UsageView DataContext="{Binding Usage}"
                             Visibility="{Binding DataContext.SubView, RelativeSource={RelativeSource AncestorType={x:Type views:TrafficView}}, Converter={StaticResource EnumVis}, ConverterParameter=Columns}" />

            <!-- world connection map -->
            <Border Background="{StaticResource BgGraph}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8"
                    ClipToBounds="True"
                    Visibility="{Binding SubView, Converter={StaticResource EnumVis}, ConverterParameter=Map}">
                <Grid>
                    <ctrl:WorldMap x:Name="Map" Margin="8" />

                    <!-- per-country drill-down (hosts talking to the clicked country) -->
                    <Border x:Name="DrillPanel" Visibility="Collapsed" Width="300" Margin="0,46,10,12"
                            HorizontalAlignment="Right" Background="{StaticResource BgPanel}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="12,10,4,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image x:Name="DrillFlag" Width="18" Height="12" Margin="0,0,9,0" VerticalAlignment="Center" />
                                    <StackPanel>
                                        <TextBlock x:Name="DrillCode" FontSize="10.5" Foreground="{StaticResource TextMuted}" />
                                        <TextBlock x:Name="DrillName" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" MaxWidth="190" />
                                    </StackPanel>
                                </StackPanel>
                                <Button x:Name="DrillClose" Style="{StaticResource IconBtn}" Width="30" Height="28"
                                        Content="&#xE711;" HorizontalAlignment="Right" VerticalAlignment="Top" Click="OnDrillClose" />
                            </Grid>
                            <TextBlock DockPanel.Dock="Top" Text="{StaticResource L.Traffic.Hosts}" Style="{StaticResource TableHeaderText}" Margin="12,0,12,4" />
                            <TextBlock x:Name="DrillFooter" DockPanel.Dock="Bottom" Style="{StaticResource Caption}" Margin="12,6,12,10" />
                            <TextBlock x:Name="DrillEmpty" DockPanel.Dock="Bottom" Visibility="Collapsed" Margin="12,8,12,4"
                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                       Text="{StaticResource L.Traffic.DrillEmpty}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="DrillHosts">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="12,5">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Host}" TextTrimming="CharacterEllipsis" MaxWidth="180"
                                                               Foreground="{StaticResource TextPrimary}" FontSize="12.5" />
                                                    <TextBlock Text="{Binding RemoteAddress}" FontSize="10.5" Foreground="{StaticResource TextMuted}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondary}" Text="{Binding Total, Converter={StaticResource Bytes}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- projection toggle + reset -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                            Background="{StaticResource BgSubtle}" CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Resources>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="mapmode" /></Style>
                            </StackPanel.Resources>
                            <RadioButton x:Name="FlatModeBtn" Content="{StaticResource L.Traffic.MapFlat}" IsChecked="True" Checked="OnFlatMode" Padding="13,5" />
                            <RadioButton x:Name="GlobeModeBtn" Content="{StaticResource L.Traffic.MapGlobe}" Checked="OnGlobeMode" Padding="13,5" />
                            <Button Style="{StaticResource IconBtn}" Width="34" Height="30" Content="&#xE72C;"
                                    ToolTip="{StaticResource L.Traffic.ResetView}" Click="OnResetView" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            </Grid>
        </Grid>

        <!-- Bottom dashboard: gauge + WAN/LAN + scrubber -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="24,14,24,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- gauge cluster -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">
                            <TextBlock Style="{StaticResource Mono}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"
                                       Text="{Binding DataContext.TotalDown, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource InLine}" VerticalAlignment="Center" />
                                <TextBlock Style="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="4,0,0,0"
                                           Text="{Binding DataContext.DownRate, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Column="1" Height="78">
                            <ctrl:GaugeArc DownValue="{Binding DataContext.DownValue, RelativeSource={RelativeSource AncestorType=Window}}"
                                           UpValue="{Binding DataContext.UpValue, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock Style="{StaticResource Mono}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"
                                           Text="{Binding DataContext.TotalCombined, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <TextBlock Text="{StaticResource L.Traffic.Total}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource Mono}" FontSize="18" FontWeight="SemiBold"
                                       Text="{Binding DataContext.TotalUp, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource OutLine}" VerticalAlignment="Center" />
                                <TextBlock Style="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="4,0,0,0"
                                           Text="{Binding DataContext.UpRate, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- WAN / LAN bars -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="40,0,0,0">
                        <StackPanel.Resources>
                            <LinearGradientBrush x:Key="BarFill" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource InFillColor}" Offset="0" />
                                <GradientStop Color="{StaticResource OutFillColor}" Offset="1" />
                            </LinearGradientBrush>
                        </StackPanel.Resources>
                        <Grid Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{StaticResource L.Traffic.Wan}" Foreground="{StaticResource TextSecondary}" FontSize="12" Width="42" VerticalAlignment="Center" />
                                <Border Width="320" Height="9" CornerRadius="5" Background="{StaticResource BgSubtle}" VerticalAlignment="Center">
                                    <Border HorizontalAlignment="Left" Height="9" CornerRadius="5" Background="{StaticResource BarFill}"
                                            Width="{Binding DataContext.WanBarWidth, RelativeSource={RelativeSource AncestorType=Window}}" />
                                </Border>
                                <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Text="{Binding DataContext.WanText, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{StaticResource L.Traffic.Lan}" Foreground="{StaticResource TextSecondary}" FontSize="12" Width="42" VerticalAlignment="Center" />
                                <Border Width="320" Height="9" CornerRadius="5" Background="{StaticResource BgSubtle}" VerticalAlignment="Center">
                                    <Border HorizontalAlignment="Left" Height="9" CornerRadius="5" Background="{StaticResource BarFill}"
                                            Width="{Binding DataContext.LanBarWidth, RelativeSource={RelativeSource AncestorType=Window}}" />
                                </Border>
                                <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Text="{Binding DataContext.LanText, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- timeline strip: mini overview + drag handles selecting the graphed window -->
                <ctrl:TimelineStrip x:Name="Strip" Height="66" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
