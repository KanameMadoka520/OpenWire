<UserControl x:Class="OpenWire.App.Views.TrafficView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:OpenWire.App.Controls"
             xmlns:views="clr-namespace:OpenWire.App.Views"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:TrafficViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Control strip -->
        <Grid Grid.Row="0" Margin="24,16,24,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Background="{StaticResource BgSubtle}">
                <StackPanel.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="subview" /></Style>
                </StackPanel.Resources>
                <RadioButton Padding="16,7" AutomationProperties.Name="GraphView" IsChecked="{Binding SubView, Converter={StaticResource EnumMatch}, ConverterParameter=Graph, Mode=TwoWay}">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" />
                </RadioButton>
                <RadioButton Padding="16,7" AutomationProperties.Name="ColumnsView" IsChecked="{Binding SubView, Converter={StaticResource EnumMatch}, ConverterParameter=Columns, Mode=TwoWay}">
                    <TextBlock Text="&#xE71C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" />
                </RadioButton>
                <RadioButton Padding="16,7" AutomationProperties.Name="MapView" IsChecked="{Binding SubView, Converter={StaticResource EnumMatch}, ConverterParameter=Map, Mode=TwoWay}">
                    <TextBlock Text="&#xE909;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" />
                </RadioButton>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Background="{StaticResource BgSubtle}">
                <StackPanel.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="trange" /></Style>
                </StackPanel.Resources>
                <RadioButton Content="5 min" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=FiveMinutes, Mode=TwoWay}" />
                <RadioButton Content="3 hours" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=ThreeHours, Mode=TwoWay}" />
                <RadioButton Content="24 hours" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Day, Mode=TwoWay}" />
                <RadioButton Content="Week" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Week, Mode=TwoWay}" />
                <RadioButton Content="Month" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Month, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <!-- Sub-views -->
        <Grid Grid.Row="1" Margin="24,0,24,0">
            <!-- graph -->
            <Border Background="{StaticResource BgGraph}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8"
                    ClipToBounds="True" Visibility="{Binding SubView, Converter={StaticResource EnumVis}, ConverterParameter=Graph}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ctrl:TrafficGraph x:Name="Graph" Grid.Row="0" />
                    <!-- breakdown bar: down/up totals + top app + top host for the view -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,7" Background="{StaticResource BgPanel}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource InLine}" VerticalAlignment="Center" />
                            <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding BreakdownDown}" />
                            <TextBlock Text="&#xE74A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource OutLine}" VerticalAlignment="Center" Margin="16,0,0,0" />
                            <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding BreakdownUp}" />
                            <Border Width="1" Background="{StaticResource Border}" Margin="16,2,16,2" />
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center" Text="{Binding TopApp}" TextTrimming="CharacterEllipsis" MaxWidth="260" />
                            <Border Width="1" Background="{StaticResource Border}" Margin="16,2,16,2" />
                            <TextBlock Text="&#xE968;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center" Text="{Binding TopHost}" TextTrimming="CharacterEllipsis" MaxWidth="260" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- columns (usage) -->
            <views:UsageView DataContext="{Binding Usage}"
                             Visibility="{Binding DataContext.SubView, RelativeSource={RelativeSource AncestorType={x:Type views:TrafficView}}, Converter={StaticResource EnumVis}, ConverterParameter=Columns}" />

            <!-- map placeholder -->
            <Border Background="{StaticResource BgGraph}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8"
                    Visibility="{Binding SubView, Converter={StaticResource EnumVis}, ConverterParameter=Map}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE909;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="44" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                    <TextBlock Text="Connection map" Foreground="{StaticResource TextSecondary}" FontSize="15" Margin="0,14,0,2" HorizontalAlignment="Center" />
                    <TextBlock Text="A world map of live connections by country is on the roadmap." Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom dashboard: gauge + WAN/LAN + scrubber -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="24,14,24,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- gauge cluster -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">
                            <TextBlock Style="{StaticResource Mono}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"
                                       Text="{Binding DataContext.TotalDown, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource InLine}" VerticalAlignment="Center" />
                                <TextBlock Style="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="4,0,0,0"
                                           Text="{Binding DataContext.DownRate, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Column="1" Height="78">
                            <ctrl:GaugeArc DownValue="{Binding DataContext.DownValue, RelativeSource={RelativeSource AncestorType=Window}}"
                                           UpValue="{Binding DataContext.UpValue, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock Style="{StaticResource Mono}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"
                                           Text="{Binding DataContext.TotalCombined, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <TextBlock Text="total" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource Mono}" FontSize="18" FontWeight="SemiBold"
                                       Text="{Binding DataContext.TotalUp, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource OutLine}" VerticalAlignment="Center" />
                                <TextBlock Style="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="4,0,0,0"
                                           Text="{Binding DataContext.UpRate, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- WAN / LAN bars -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="40,0,0,0">
                        <StackPanel.Resources>
                            <LinearGradientBrush x:Key="BarFill" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource InFillColor}" Offset="0" />
                                <GradientStop Color="{StaticResource OutFillColor}" Offset="1" />
                            </LinearGradientBrush>
                        </StackPanel.Resources>
                        <Grid Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="WAN" Foreground="{StaticResource TextSecondary}" FontSize="12" Width="42" VerticalAlignment="Center" />
                                <Border Width="320" Height="9" CornerRadius="5" Background="{StaticResource BgSubtle}" VerticalAlignment="Center">
                                    <Border HorizontalAlignment="Left" Height="9" CornerRadius="5" Background="{StaticResource BarFill}"
                                            Width="{Binding DataContext.WanBarWidth, RelativeSource={RelativeSource AncestorType=Window}}" />
                                </Border>
                                <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Text="{Binding DataContext.WanText, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="LAN" Foreground="{StaticResource TextSecondary}" FontSize="12" Width="42" VerticalAlignment="Center" />
                                <Border Width="320" Height="9" CornerRadius="5" Background="{StaticResource BgSubtle}" VerticalAlignment="Center">
                                    <Border HorizontalAlignment="Left" Height="9" CornerRadius="5" Background="{StaticResource BarFill}"
                                            Width="{Binding DataContext.LanBarWidth, RelativeSource={RelativeSource AncestorType=Window}}" />
                                </Border>
                                <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Text="{Binding DataContext.LanText, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- timeline scrubber (decorative) -->
                <Border Height="30" Background="{StaticResource BgSubtle}" CornerRadius="6" Margin="0,12,0,0">
                    <Grid>
                        <Ellipse Width="12" Height="12" Fill="{StaticResource BgPanel}" Stroke="{StaticResource BorderStrong}" StrokeThickness="1.5" HorizontalAlignment="Left" Margin="4,0,0,0" />
                        <Ellipse Width="12" Height="12" Fill="{StaticResource BgPanel}" Stroke="{StaticResource BorderStrong}" StrokeThickness="1.5" HorizontalAlignment="Right" Margin="0,0,4,0" />
                        <TextBlock Text="drag to scrub history" Style="{StaticResource Caption}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
