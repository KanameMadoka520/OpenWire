<UserControl x:Class="OpenWire.App.Views.UsageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:UsageViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <UserControl.Resources>
        <Style x:Key="ColCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- APPLICATIONS -->
        <Border Grid.Column="0" Style="{StaticResource ColCard}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="APPLICATIONS" Style="{StaticResource TableHeaderText}" Margin="14,12,14,8" />
                <ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}" ItemsSource="{Binding Apps}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="14,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="16" Height="16" Margin="0,0,9,0" Source="{Binding App.ExecutablePath, Converter={StaticResource AppIcon}}" />
                                    <TextBlock Text="{Binding App.Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="150" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- HOSTS -->
        <Border Grid.Column="1" Style="{StaticResource ColCard}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="HOSTS" Style="{StaticResource TableHeaderText}" Margin="14,12,14,8" />
                <ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}" ItemsSource="{Binding Hosts}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="14,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Host}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="170" />
                                <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- TRAFFIC TYPES -->
        <Border Grid.Column="2" Style="{StaticResource ColCard}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="TRAFFIC TYPES" Style="{StaticResource TableHeaderText}" Margin="14,12,14,8" />
                <ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}" ItemsSource="{Binding Types}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="14,7">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TypeName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="150" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                               Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                                </Grid>
                                <Border Height="4" CornerRadius="2" Background="{StaticResource InFill}" HorizontalAlignment="Left" Margin="0,6,0,0"
                                        Width="{Binding Fraction, Converter={StaticResource FracW}, ConverterParameter=190}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- COUNTRIES -->
        <Border Grid.Column="3" Style="{StaticResource ColCard}" Margin="0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="COUNTRIES" Style="{StaticResource TableHeaderText}" Margin="14,12,14,8" />
                <ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}" ItemsSource="{Binding Countries}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="14,7">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource BgSubtle}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0"
                                                Visibility="{Binding CountryCode.Length, Converter={StaticResource ZeroVis}}">
                                            <TextBlock Text="{Binding CountryCode}" FontSize="10" Foreground="{StaticResource TextSecondary}" />
                                        </Border>
                                        <TextBlock Text="{Binding CountryName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="120" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                               Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                                </Grid>
                                <Border Height="4" CornerRadius="2" Background="{StaticResource OutFill}" HorizontalAlignment="Left" Margin="0,6,0,0"
                                        Width="{Binding Fraction, Converter={StaticResource FracW}, ConverterParameter=190}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
