<UserControl x:Class="OpenWire.App.Views.UsageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:UsageViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <UserControl.Resources>
        <Style x:Key="ColCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
    <!-- Slim toolbar: export the current usage breakdown to CSV. -->
    <Grid DockPanel.Dock="Top" Margin="0,0,10,10">
        <Button HorizontalAlignment="Right" Style="{StaticResource BtnGhost}" Padding="10,5" Command="{Binding ExportCsvCommand}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12.5" VerticalAlignment="Center" Margin="0,0,7,0" />
                <TextBlock Text="{StaticResource L.Usage.Export}" VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>

    <!-- Four dimension columns. A UniformGrid (not a 4-star Grid) so that when the filter
         panel opens and hides its matching column, the remaining columns redistribute evenly
         instead of leaving a gap. The -10 right margin cancels the last card's trailing gutter. -->
    <UniformGrid Rows="1" Margin="0,0,-10,0">

        <!-- APPLICATIONS -->
        <Border Style="{StaticResource ColCard}"
                Visibility="{Binding FilterDimension, Converter={StaticResource ColHide}, ConverterParameter=0}">
            <DockPanel>
                <!-- Clickable header: toggles this column between total (high→low) and name (A→Z); arrow shows the active direction. -->
                <Button DockPanel.Dock="Top" Style="{StaticResource SortHeaderBtn}" Margin="14,12,14,8"
                        Command="{Binding SortColumnCommand}" CommandParameter="apps">
                    <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Usage.Applications}" /><Run>
                        <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="name"><Binding Path="AppsSort.Key" /><Binding Path="AppsSort.Ascending" /></MultiBinding></Run.Text></Run><Run>
                        <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="total"><Binding Path="AppsSort.Key" /><Binding Path="AppsSort.Ascending" /></MultiBinding></Run.Text></Run></TextBlock>
                </Button>
                <ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}" ItemsSource="{Binding Apps}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="14,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Width="16" Height="16" Margin="0,0,9,0" VerticalAlignment="Center" Source="{Binding App.ExecutablePath, Converter={StaticResource AppIcon}}" />
                                <TextBlock Grid.Column="1" Text="{Binding App.Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="8,0,0,0"
                                           Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- HOSTS -->
        <Border Style="{StaticResource ColCard}"
                Visibility="{Binding FilterDimension, Converter={StaticResource ColHide}, ConverterParameter=1}">
            <DockPanel>
                <Button DockPanel.Dock="Top" Style="{StaticResource SortHeaderBtn}" Margin="14,12,14,8"
                        Command="{Binding SortColumnCommand}" CommandParameter="hosts">
                    <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Usage.Hosts}" /><Run>
                        <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="name"><Binding Path="HostsSort.Key" /><Binding Path="HostsSort.Ascending" /></MultiBinding></Run.Text></Run><Run>
                        <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="total"><Binding Path="HostsSort.Key" /><Binding Path="HostsSort.Ascending" /></MultiBinding></Run.Text></Run></TextBlock>
                </Button>
                <ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}" ItemsSource="{Binding Hosts}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="14,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Width="16" Height="11" Margin="0,0,7,0" VerticalAlignment="Center"
                                       Source="{Binding Geo.CountryCode, Converter={StaticResource Flag}}" />
                                <TextBlock Grid.Column="1" Text="{Binding Host}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="8,0,0,0"
                                           Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- TRAFFIC TYPES -->
        <Border Style="{StaticResource ColCard}"
                Visibility="{Binding FilterDimension, Converter={StaticResource ColHide}, ConverterParameter=2}">
            <DockPanel>
                <Button DockPanel.Dock="Top" Style="{StaticResource SortHeaderBtn}" Margin="14,12,14,8"
                        Command="{Binding SortColumnCommand}" CommandParameter="types">
                    <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Usage.TrafficTypes}" /><Run>
                        <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="name"><Binding Path="TypesSort.Key" /><Binding Path="TypesSort.Ascending" /></MultiBinding></Run.Text></Run><Run>
                        <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="total"><Binding Path="TypesSort.Key" /><Binding Path="TypesSort.Ascending" /></MultiBinding></Run.Text></Run></TextBlock>
                </Button>
                <ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}" ItemsSource="{Binding Types}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="14,7">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TypeName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="8,0,0,0"
                                               Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                                </Grid>
                                <Border Height="4" CornerRadius="2" Background="{StaticResource InFill}" HorizontalAlignment="Left" Margin="0,6,0,0"
                                        Width="{Binding Fraction, Converter={StaticResource FracW}, ConverterParameter=190}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- COUNTRIES -->
        <Border Style="{StaticResource ColCard}"
                Visibility="{Binding FilterDimension, Converter={StaticResource ColHide}, ConverterParameter=3}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="14,12,14,8">
                    <Button Style="{StaticResource SortHeaderBtn}" VerticalAlignment="Center"
                            Command="{Binding SortColumnCommand}" CommandParameter="countries">
                        <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Usage.CountriesRegions}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="name"><Binding Path="CountriesSort.Key" /><Binding Path="CountriesSort.Ascending" /></MultiBinding></Run.Text></Run><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="total"><Binding Path="CountriesSort.Key" /><Binding Path="CountriesSort.Ascending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource TextMuted}" Margin="6,0,0,0" VerticalAlignment="Center"
                               ToolTipService.InitialShowDelay="150" ToolTipService.ShowDuration="30000"
                               ToolTip="{StaticResource L.Common.OneChina}" />
                </StackPanel>
                <ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource PlainRow}" ItemsSource="{Binding Countries}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="14,7">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Width="16" Height="11" Margin="0,0,8,0" VerticalAlignment="Center"
                                           Source="{Binding CountryCode, Converter={StaticResource Flag}}" />
                                    <Border Grid.Column="1" Background="{StaticResource BgSubtle}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0" VerticalAlignment="Center"
                                            Visibility="{Binding DisplayCode.Length, Converter={StaticResource ZeroVis}}">
                                        <TextBlock Text="{Binding DisplayCode}" FontSize="10" Foreground="{StaticResource TextSecondary}" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Converter={StaticResource CountryDisplay}}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="8,0,0,0"
                                               Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                                </Grid>
                                <Border Height="4" CornerRadius="2" Background="{StaticResource OutFill}" HorizontalAlignment="Left" Margin="0,6,0,0"
                                        Width="{Binding Fraction, Converter={StaticResource FracW}, ConverterParameter=190}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </UniformGrid>
    </DockPanel>
</UserControl>
