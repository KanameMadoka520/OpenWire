<UserControl x:Class="OpenWire.App.Views.HardwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:OpenWire.App.Controls"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:HardwareViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Hardware resources" Style="{StaticResource H1}" Margin="0,0,0,10" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Top" Text="CPU" Style="{StaticResource TableHeaderText}" Margin="2,0,0,2" />
                <ctrl:MetricGraph x:Name="CpuGraph" />
            </DockPanel>
            <DockPanel Grid.Row="1" Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Top" Text="MEMORY" Style="{StaticResource TableHeaderText}" Margin="2,0,0,2" />
                <ctrl:MetricGraph x:Name="MemGraph" />
            </DockPanel>
            <DockPanel Grid.Row="2" Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Top" Text="DISK TRANSFER" Style="{StaticResource TableHeaderText}" Margin="2,0,0,2" />
                <ctrl:MetricGraph x:Name="DiskGraph" />
            </DockPanel>
            <DockPanel Grid.Row="3" Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Top" Text="GPU" Style="{StaticResource TableHeaderText}" Margin="2,0,0,2" />
                <ctrl:MetricGraph x:Name="GpuGraph" />
            </DockPanel>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="0,14,0,14" Margin="0,8,0,0">
            <UniformGrid Rows="1" Columns="4">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Style="{StaticResource Mono}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding CpuText}" />
                    <TextBlock Text="CPU usage" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Style="{StaticResource Mono}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding MemoryText}" />
                    <TextBlock Text="Memory used" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Style="{StaticResource Mono}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding DiskReadText}" />
                    <TextBlock Text="Disk read" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Style="{StaticResource Mono}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding GpuText}" />
                    <TextBlock Text="GPU usage" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                </StackPanel>
            </UniformGrid>
        </Border>
    </Grid>
</UserControl>
