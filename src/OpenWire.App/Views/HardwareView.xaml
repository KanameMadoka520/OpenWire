<UserControl x:Class="OpenWire.App.Views.HardwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:OpenWire.App.Controls"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:HardwareViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,16,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{StaticResource L.Hw.Title}" Style="{StaticResource H1}" VerticalAlignment="Center" />
            <TextBlock Text="{StaticResource L.Hw.Last5Minutes}" Foreground="{StaticResource TextSecondary}" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <!-- LEFT: per-process resource table · RIGHT: the live graphs + stat row -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.44*" MinWidth="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="0.56*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <!-- ============ Process table ============ -->
            <Grid Grid.Column="0" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{StaticResource L.Hw.Processes}" Style="{StaticResource TableHeaderText}" Margin="2,0,0,4" />

                <!-- Clickable sort headers (label + a ▲/▼ arrow on the active column).
                     The 16px right margin reserves room for the rows' scrollbar so the
                     header columns stay aligned with the rows below. -->
                <Grid Grid.Row="1" Margin="0,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="84" />
                    </Grid.ColumnDefinitions>
                    <Grid.Resources>
                        <Style x:Key="HdrText" TargetType="TextBlock" BasedOn="{StaticResource TableHeaderText}" />
                    </Grid.Resources>
                    <Button Grid.Column="0" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="name">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Hw.ColApplication}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="name"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="cpu">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Hw.Cpu}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="cpu"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="gpu">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Hw.Gpu}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="gpu"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="mem">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Hw.Memory}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="mem"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                    <Button Grid.Column="4" Style="{StaticResource SortHeaderBtn}" Command="{Binding SortByCommand}" CommandParameter="disk">
                        <TextBlock Style="{StaticResource HdrText}"><Run Text="{StaticResource L.Hw.ColDisk}" /><Run>
                            <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="disk"><Binding Path="SortKey" /><Binding Path="SortAscending" /></MultiBinding></Run.Text></Run></TextBlock>
                    </Button>
                </Grid>

                <!-- Rows: a ListBox virtualizes + recycles containers, so only the
                     visible slice of the ~40-process list is ever realized. -->
                <ListBox Grid.Row="2" ItemsSource="{Binding Processes}" Background="Transparent" BorderThickness="0" Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="0,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="84" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Width="18" Height="18" Margin="0,0,10,0" Source="{Binding Path, Converter={StaticResource AppIcon}}" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" Text="{Binding CpuText}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource Mono}" FontSize="12" Text="{Binding GpuText}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}" Text="{Binding MemoryText}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}" Text="{Binding DiskText}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="11,0"
                          Background="{StaticResource Border}" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />

            <!-- ============ Live graphs + stat row (unchanged) ============ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Top" Text="{StaticResource L.Hw.Cpu}" Style="{StaticResource TableHeaderText}" Margin="2,0,0,2" />
                        <ctrl:MetricGraph x:Name="CpuGraph" />
                    </DockPanel>
                    <DockPanel Grid.Row="1" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Top" Text="{StaticResource L.Hw.Memory}" Style="{StaticResource TableHeaderText}" Margin="2,0,0,2" />
                        <ctrl:MetricGraph x:Name="MemGraph" />
                    </DockPanel>
                    <DockPanel Grid.Row="2" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Top" Text="{StaticResource L.Hw.DiskTransfer}" Style="{StaticResource TableHeaderText}" Margin="2,0,0,2" />
                        <ctrl:MetricGraph x:Name="DiskGraph" />
                    </DockPanel>
                    <DockPanel Grid.Row="3" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Top" Text="{StaticResource L.Hw.Gpu}" Style="{StaticResource TableHeaderText}" Margin="2,0,0,2" />
                        <ctrl:MetricGraph x:Name="GpuGraph" />
                    </DockPanel>
                </Grid>

                <!-- time axis -->
                <ItemsControl Grid.Row="1" x:Name="TimeAxis" Margin="0,2,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="0,14,0,14" Margin="0,8,0,0">
                    <UniformGrid Rows="1" Columns="6">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Mono}" FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding CpuText}" />
                            <TextBlock Text="{StaticResource L.Hw.CpuUsage}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Mono}" FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding MemoryText}" />
                            <TextBlock Text="{StaticResource L.Hw.MemoryUsed}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Mono}" FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding DiskReadText}" />
                            <TextBlock Text="{StaticResource L.Hw.DiskRead}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Mono}" FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding DiskWriteText}" />
                            <TextBlock Text="{StaticResource L.Hw.DiskWrite}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Mono}" FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding GpuText}" />
                            <TextBlock Text="{StaticResource L.Hw.GpuUsage}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Mono}" FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding GpuMemoryText}" />
                            <TextBlock Text="{StaticResource L.Hw.GpuMemory}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </UniformGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
