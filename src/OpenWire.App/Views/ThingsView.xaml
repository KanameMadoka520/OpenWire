<UserControl x:Class="OpenWire.App.Views.ThingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             xmlns:local="clr-namespace:OpenWire.App.Views"
             d:DataContext="{d:DesignInstance vm:ThingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="{StaticResource BgSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="12,7">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE701;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Success}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding NetworkName}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Button Content="{Binding ScanLabel}" Style="{StaticResource Btn}" Margin="12,0,0,0" Command="{Binding ScanCommand}"
                        IsEnabled="{Binding Scanning, Converter={StaticResource BoolVis}, ConverterParameter=invert}" />
                <TextBlock Text="{Binding LastScanText}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="14,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Grid Width="220" Margin="0,0,12,0">
                    <TextBox Style="{StaticResource Search}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="{StaticResource L.Scan.SearchDevices}" Foreground="{StaticResource TextMuted}" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                               Visibility="{Binding SearchText.Length, Converter={StaticResource ZeroVis}, ConverterParameter=invert}" />
                </Grid>
                <TextBlock Text="{StaticResource L.Scan.RescanEvery}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- empty state (pre-scan / no devices) -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasDevices, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <TextBlock Text="&#xE701;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="46"
                       Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
            <TextBlock Text="{StaticResource L.Scan.EmptyTitle}" Foreground="{StaticResource TextSecondary}" FontSize="15"
                       HorizontalAlignment="Center" Margin="0,16,0,2" />
            <TextBlock Text="{StaticResource L.Scan.EmptyHint}" Style="{StaticResource Caption}"
                       HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="360" />
            <Button Content="{Binding ScanLabel}" Style="{StaticResource Btn}" Command="{Binding ScanCommand}"
                    HorizontalAlignment="Center" Margin="0,18,0,0"
                    IsEnabled="{Binding Scanning, Converter={StaticResource BoolVis}, ConverterParameter=invert}" />
        </StackPanel>

        <ListView x:Name="DeviceList" Grid.Row="1" Style="{StaticResource Table}" ItemContainerStyle="{StaticResource Row}" ItemsSource="{Binding Devices}"
                  Visibility="{Binding HasDevices, Converter={StaticResource BoolVis}}">
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource ColHeader}">
                    <GridViewColumn Width="240" local:ThingsView.SortField="name">
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Scan.ColDevice}" /><Run>
                                <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="name">
                                    <Binding Path="DataContext.SortField" RelativeSource="{RelativeSource AncestorType=ListView}" />
                                    <Binding Path="DataContext.SortAscending" RelativeSource="{RelativeSource AncestorType=ListView}" /></MultiBinding></Run.Text></Run></TextBlock>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource TextMuted}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="True"><Setter Property="Fill" Value="{StaticResource Success}" /></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding Kind, Converter={StaticResource DevGlyph}}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="150" local:ThingsView.SortField="description">
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Scan.ColDescription}" /><Run>
                                <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="description">
                                    <Binding Path="DataContext.SortField" RelativeSource="{RelativeSource AncestorType=ListView}" />
                                    <Binding Path="DataContext.SortAscending" RelativeSource="{RelativeSource AncestorType=ListView}" /></MultiBinding></Run.Text></Run></TextBlock>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondary}" FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="120" local:ThingsView.SortField="system">
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Scan.ColSystem}" /><Run>
                                <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="system">
                                    <Binding Path="DataContext.SortField" RelativeSource="{RelativeSource AncestorType=ListView}" />
                                    <Binding Path="DataContext.SortAscending" RelativeSource="{RelativeSource AncestorType=ListView}" /></MultiBinding></Run.Text></Run></TextBlock>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Text="{Binding OperatingSystem}" Foreground="{StaticResource TextSecondary}" FontSize="12.5" VerticalAlignment="Center" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="130" local:ThingsView.SortField="ip">
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Scan.ColIp}" /><Run>
                                <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="ip">
                                    <Binding Path="DataContext.SortField" RelativeSource="{RelativeSource AncestorType=ListView}" />
                                    <Binding Path="DataContext.SortAscending" RelativeSource="{RelativeSource AncestorType=ListView}" /></MultiBinding></Run.Text></Run></TextBlock>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Style="{StaticResource Mono}" FontSize="12.5" Foreground="{StaticResource TextSecondary}" Text="{Binding IpAddress}" VerticalAlignment="Center" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="150" local:ThingsView.SortField="mac">
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Scan.ColMac}" /><Run>
                                <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="mac">
                                    <Binding Path="DataContext.SortField" RelativeSource="{RelativeSource AncestorType=ListView}" />
                                    <Binding Path="DataContext.SortAscending" RelativeSource="{RelativeSource AncestorType=ListView}" /></MultiBinding></Run.Text></Run></TextBlock>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextMuted}" Text="{Binding MacAddress}" VerticalAlignment="Center" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="130" local:ThingsView.SortField="lastseen">
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Scan.ColLastSeen}" /><Run>
                                <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="lastseen">
                                    <Binding Path="DataContext.SortField" RelativeSource="{RelativeSource AncestorType=ListView}" />
                                    <Binding Path="DataContext.SortAscending" RelativeSource="{RelativeSource AncestorType=ListView}" /></MultiBinding></Run.Text></Run></TextBlock>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"
                                       Text="{Binding LastSeen, Converter={StaticResource LocalTime}, ConverterParameter='MMM d  HH:mm'}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="130" local:ThingsView.SortField="firstseen">
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource TableHeaderText}"><Run Text="{StaticResource L.Scan.ColFirstSeen}" /><Run>
                                <Run.Text><MultiBinding Converter="{StaticResource SortArrow}" ConverterParameter="firstseen">
                                    <Binding Path="DataContext.SortField" RelativeSource="{RelativeSource AncestorType=ListView}" />
                                    <Binding Path="DataContext.SortAscending" RelativeSource="{RelativeSource AncestorType=ListView}" /></MultiBinding></Run.Text></Run></TextBlock>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"
                                       Text="{Binding FirstSeen, Converter={StaticResource LocalTime}, ConverterParameter='MMM d  HH:mm'}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="" Width="52">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <Button Style="{StaticResource IconBtn}" Width="30" Height="30" Content="&#xE74D;" FontSize="13" ToolTip="{StaticResource L.Scan.ForgetDevice}"
                                    Command="{Binding DataContext.ForgetCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
