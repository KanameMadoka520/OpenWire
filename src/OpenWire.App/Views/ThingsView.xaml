<UserControl x:Class="OpenWire.App.Views.ThingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:ThingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Things" Style="{StaticResource H1}" />
                <TextBlock Text="Devices on your local network" Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <Button Content="{Binding ScanLabel}" Style="{StaticResource Btn}" HorizontalAlignment="Right"
                    Command="{Binding ScanCommand}" IsEnabled="{Binding Scanning, Converter={StaticResource BoolVis}, ConverterParameter=invert}" />
        </Grid>

        <ListView Grid.Row="1" Style="{StaticResource Table}" ItemContainerStyle="{StaticResource Row}" ItemsSource="{Binding Devices}">
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource ColHeader}">
                    <GridViewColumn Header="DEVICE" Width="280">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Kind, Converter={StaticResource DevGlyph}}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="17" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Text="{Binding Vendor}" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IP ADDRESS" Width="140">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Style="{StaticResource Mono}" Foreground="{StaticResource TextSecondary}" Text="{Binding IpAddress}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="MAC" Width="160">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Style="{StaticResource Mono}" Foreground="{StaticResource TextMuted}" FontSize="12" Text="{Binding MacAddress}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="FIRST SEEN" Width="140">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12"
                                       Text="{Binding FirstSeen, Converter={StaticResource LocalTime}, ConverterParameter='MMM d'}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="STATUS" Width="120">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource TextMuted}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Success}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Offline" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                    <Setter Property="Text" Value="Online" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="" Width="60">
                        <GridViewColumn.CellTemplate><DataTemplate>
                            <Button Style="{StaticResource IconBtn}" Width="30" Height="30" Content="&#xE74D;" FontSize="13"
                                    ToolTip="Forget device"
                                    Command="{Binding DataContext.ForgetCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate></GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
