<UserControl x:Class="OpenWire.App.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:OpenWire.App.Controls"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:AnalyticsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="Padding" Value="15,12" />
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock" BasedOn="{StaticResource Mono}">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Control strip: title + range -->
        <Grid Grid.Row="0" Margin="24,16,24,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Analytics" Style="{StaticResource H1}" />
                <TextBlock Text="usage patterns &amp; anomalies" Style="{StaticResource Caption}" VerticalAlignment="Bottom" Margin="10,0,0,3" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Background="{StaticResource BgSubtle}">
                <StackPanel.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}"><Setter Property="GroupName" Value="arange" /></Style>
                </StackPanel.Resources>
                <RadioButton Content="24 hours" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Day, Mode=TwoWay}" />
                <RadioButton Content="Week" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Week, Mode=TwoWay}" />
                <RadioButton Content="Month" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Month, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,6,18,20">
            <StackPanel>

                <!-- Summary cards -->
                <UniformGrid Rows="1" Columns="5" Margin="0,4,0,14">
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="TOTAL" Style="{StaticResource TableHeaderText}" />
                            <TextBlock Text="{Binding TotalText}" Style="{StaticResource StatValue}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding DownUpText}" Style="{StaticResource Caption}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="CHANGE" Style="{StaticResource TableHeaderText}" />
                            <TextBlock Text="{Binding ChangeText}" Style="{StaticResource StatValue}" FontSize="15" Margin="0,6,0,0" />
                            <TextBlock Text="period over period" Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="BUSIEST HOUR" Style="{StaticResource TableHeaderText}" />
                            <TextBlock Text="{Binding BusiestHourText}" Style="{StaticResource StatValue}" Margin="0,4,0,0" />
                            <TextBlock Text="local time" Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="AVG / DAY" Style="{StaticResource TableHeaderText}" />
                            <TextBlock Text="{Binding PerDayText}" Style="{StaticResource StatValue}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding ActiveDaysText}" Style="{StaticResource Caption}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="ACTIVE APPS" Style="{StaticResource TableHeaderText}" />
                            <TextBlock Text="{Binding ActiveAppsText}" Style="{StaticResource StatValue}" Margin="0,4,0,0" />
                            <TextBlock Text="moved bytes" Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Pattern charts -->
                <Grid Margin="6,0,6,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,7,0" Height="224">
                        <DockPanel Margin="16,12">
                            <TextBlock DockPanel.Dock="Top" Text="WHEN YOU USE THE NETWORK — BY HOUR" Style="{StaticResource TableHeaderText}" Margin="0,0,0,6" />
                            <ctrl:BarChart x:Name="HourChart" />
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,0,0" Height="224">
                        <DockPanel Margin="16,12">
                            <TextBlock DockPanel.Dock="Top" Text="DAILY USAGE" Style="{StaticResource TableHeaderText}" Margin="0,0,0,6" />
                            <ctrl:BarChart x:Name="DayChart" />
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Highlights + top apps | anomalies -->
                <Grid Margin="6,0,6,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,7,0">
                        <!-- Highlights -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel Margin="16,14">
                                <TextBlock Text="HIGHLIGHTS" Style="{StaticResource TableHeaderText}" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding Highlights}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource Accent}" VerticalAlignment="Top" Margin="0,6,10,0" />
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" MaxWidth="440" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <!-- Top apps -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel Margin="16,14">
                                <TextBlock Text="TOP APPLICATIONS" Style="{StaticResource TableHeaderText}" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding TopApps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Width="16" Height="16" Margin="0,0,9,0" Source="{Binding ExecutablePath, Converter={StaticResource AppIcon}}" />
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="240" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                                               Text="{Binding Total, Converter={StaticResource Bytes}}" VerticalAlignment="Center" />
                                                </Grid>
                                                <Border Height="4" CornerRadius="2" Background="{StaticResource Accent}" HorizontalAlignment="Left" Margin="25,5,0,0"
                                                        Width="{Binding Fraction, Converter={StaticResource FracW}, ConverterParameter=300}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Anomalies -->
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,0,0">
                        <StackPanel Margin="16,14">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="ANOMALIES DETECTED" Style="{StaticResource TableHeaderText}" VerticalAlignment="Center" />
                                <Border Background="{StaticResource BgSubtle}" CornerRadius="9" Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding HasAnomalies, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{Binding Anomalies.Count}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" />
                                </Border>
                            </StackPanel>

                            <!-- empty state -->
                            <StackPanel Margin="0,14" Visibility="{Binding HasAnomalies, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="26"
                                           Foreground="{StaticResource Success}" HorizontalAlignment="Center" />
                                <TextBlock Text="No anomalies detected." Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                <TextBlock Text="Your recorded usage looks normal for this period." Style="{StaticResource Caption}"
                                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,2,0,0" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Anomalies}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgSubtle}" CornerRadius="6" Padding="12,10" Margin="0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Kind, Converter={StaticResource AnomGlyph}}"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16"
                                                           Foreground="{Binding Severity, Converter={StaticResource SevBrush}}" VerticalAlignment="Top" Margin="0,1,11,0" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
