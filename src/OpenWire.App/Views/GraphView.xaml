<UserControl x:Class="OpenWire.App.Views.GraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:OpenWire.App.Controls"
             xmlns:vm="clr-namespace:OpenWire.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:GraphViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <!-- Control strip -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Network activity" Style="{StaticResource H1}" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Background="{StaticResource BgPanel}">
                <StackPanel.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource Seg}">
                        <Setter Property="GroupName" Value="range" />
                    </Style>
                </StackPanel.Resources>
                <RadioButton Content="5 min" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=FiveMinutes, Mode=TwoWay}" />
                <RadioButton Content="3 hours" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=ThreeHours, Mode=TwoWay}" />
                <RadioButton Content="Day" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Day, Mode=TwoWay}" />
                <RadioButton Content="Week" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Week, Mode=TwoWay}" />
                <RadioButton Content="Month" IsChecked="{Binding Range, Converter={StaticResource EnumMatch}, ConverterParameter=Month, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <!-- Graph canvas -->
        <Border Grid.Row="1" Background="{StaticResource BgGraph}" BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="6">
            <Grid ClipToBounds="True">
                <ctrl:TrafficGraph x:Name="Graph" />
                <!-- direction legend + live speeds -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="12" Background="Transparent">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource InLine}" VerticalAlignment="Center" />
                    <TextBlock Text="Download" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="6,0,4,0" VerticalAlignment="Center" />
                    <TextBlock Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"
                               Text="{Binding DataContext.DownRate, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Ellipse Width="9" Height="9" Fill="{StaticResource OutLine}" VerticalAlignment="Center" Margin="18,0,0,0" />
                    <TextBlock Text="Upload" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="6,0,4,0" VerticalAlignment="Center" />
                    <TextBlock Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"
                               Text="{Binding DataContext.UpRate, RelativeSource={RelativeSource AncestorType=Window}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Breakdown header -->
        <TextBlock Grid.Row="2" Text="Top applications" Style="{StaticResource TableHeaderText}" Margin="2,18,0,8" />

        <!-- Top apps -->
        <ListView Grid.Row="3" Style="{StaticResource Table}" ItemContainerStyle="{StaticResource Row}"
                  ItemsSource="{Binding TopApps}">
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource ColHeader}">
                    <GridViewColumn Header="APPLICATION" Width="360">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="18" Height="18" Margin="0,0,10,0"
                                           Source="{Binding App.ExecutablePath, Converter={StaticResource AppIcon}}" />
                                    <TextBlock Text="{Binding App.Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="DOWNLOAD" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource Mono}" Foreground="{StaticResource InLine}"
                                           Text="{Binding BytesIn, Converter={StaticResource Bytes}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="UPLOAD" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource Mono}" Foreground="{StaticResource OutLine}"
                                           Text="{Binding BytesOut, Converter={StaticResource Bytes}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="CONNECTIONS" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource Mono}" Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding ActiveConnections}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
