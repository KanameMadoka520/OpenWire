<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         PENCIL-SKETCH RPG kit: paper texture, hand font, hand-drawn
         doodle artwork (original), sketch frames, XP bar, wax stamp.
         All artwork is authored here as vector Path data (clean-room).
         ============================================================ -->

    <FontFamily x:Key="HandFont">Ink Free, Segoe Print, Comic Sans MS, Segoe UI</FontFamily>

    <!-- Faint paper grain: tiled graphite speckles over the paper colour. -->
