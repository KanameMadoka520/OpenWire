    <!-- Path skins for scattered doodles -->
    <Style x:Key="Doodle" TargetType="Path">
        <Setter Property="Stroke" Value="{StaticResource Graphite}" />
        <Setter Property="StrokeThickness" Value="1.7" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Opacity" Value="0.16" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="False" />
    </Style>

    <!-- Filled doodle (stars / sparkles) -->
    <Style x:Key="DoodleFill" TargetType="Path" BasedOn="{StaticResource Doodle}">
        <Setter Property="Fill" Value="{StaticResource Graphite}" />
        <Setter Property="Stroke" Value="{x:Null}" />
        <Setter Property="Opacity" Value="0.14" />
    </Style>

    <!-- A slightly bolder doodle for a screen's "hero" motif -->
    <Style x:Key="DoodleHero" TargetType="Path" BasedOn="{StaticResource Doodle}">
        <Setter Property="StrokeThickness" Value="2.1" />
        <Setter Property="Opacity" Value="0.13" />
    </Style>

    <!-- ============ Sketch frame: paper card with a hand-drawn offset edge ============ -->
    <DropShadowEffect x:Key="SketchLift" Color="{StaticResource GraphiteColor}" BlurRadius="0" ShadowDepth="2.4" Direction="300" Opacity="0.28" />

    <Style x:Key="SketchCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgPanel}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}" />
        <Setter Property="BorderThickness" Value="1.4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Effect" Value="{StaticResource SketchLift}" />
    </Style>

    <!-- ============ RPG XP / progress bar (hand-drawn track + fill) ============ -->
    <Style x:Key="XpBar" TargetType="Border">
        <Setter Property="Height" Value="12" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{StaticResource BgSubtle}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}" />
        <Setter Property="BorderThickness" Value="1.2" />
    </Style>

    <!-- ============ Wax-stamp / seal badge ============ -->
    <Style x:Key="StampBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource AccentSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        <Setter Property="BorderThickness" Value="1.3" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <!-- Quest-log heading: hand font, underlined by a squiggle where used -->
    <Style x:Key="Quest" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HandFont}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="22" />
    </Style>

</ResourceDictionary>
