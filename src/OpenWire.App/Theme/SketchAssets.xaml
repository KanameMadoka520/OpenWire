<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Skin-independent assets: fonts, the paper-grain texture, and the original
         hand-drawn doodle geometries. Loaded before any skin, so skins/controls can
         reference these. The doodles' *visibility* is controlled per-skin via the
         DoodleInk brush (transparent in the Minimal skin). -->

    <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI, Inter</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Segoe UI</FontFamily>
    <FontFamily x:Key="HandFont">Ink Free, Segoe Print, Comic Sans MS, Segoe UI</FontFamily>

